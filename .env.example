# ============================================================
#  BU MotoSpace — Environment Configuration
#  คัดลอกไฟล์นี้แล้วเปลี่ยนชื่อเป็น .env
#  cp .env.example .env
#  จากนั้นแก้ไขค่าให้ตรงกับสภาพแวดล้อมของคุณ
# ============================================================

# ── Database (MariaDB / MySQL) ────────────────────────────
DB_HOST=127.0.0.1        # IP หรือ hostname ของ MariaDB
DB_PORT=3306             # port ของ MariaDB (default: 3306)
DB_USER=asset_user       # ชื่อ user ของ database
DB_PASSWORD=CHANGE_ME    # รหัสผ่าน database (ห้ามใช้ค่านี้จริง!)
DB_NAME=bu_motospace     # ชื่อ database

# ── Application ───────────────────────────────────────────
NODE_ENV=production
APP_PORT=3000            # port ที่ app จะรันบน server

# ── Security Secrets ──────────────────────────────────────
#  ⚠️  สุ่มค่าใหม่ทุกครั้งที่ deploy บน server ใหม่
#  วิธีสุ่ม: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

SESSION_SECRET=CHANGE_ME_USE_RANDOM_STRING_MIN_32_CHARS
IMAGE_SECRET=CHANGE_ME_USE_DIFFERENT_RANDOM_STRING_MIN_32_CHARS
DEFAULT_ADMIN_PASSWORD=CHANGE_ME_FIRST_ADMIN_PASSWORD_MIN_12_CHARS

# ── reCAPTCHA v3 (Google) ─────────────────────────────────
#  สมัครได้ที่ https://www.google.com/recaptcha/admin/create
#  เลือกประเภท: reCAPTCHA v3
RECAPTCHA_SITE_KEY=CHANGE_ME_RECAPTCHA_V3_SITE_KEY
RECAPTCHA_SECRET_KEY=CHANGE_ME_RECAPTCHA_V3_SECRET_KEY
