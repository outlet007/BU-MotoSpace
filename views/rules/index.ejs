<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/output.css">
  <script src="https://unpkg.com/lucide@latest"></script>
  <style>
    .glass { background: rgba(255,255,255,0.7); backdrop-filter: blur(12px); }
    .fade-in { animation: fadeIn 0.3s ease-in; }
    @keyframes fadeIn { from { opacity:0; transform:translateY(8px); } to { opacity:1; transform:translateY(0); } }
    .sidebar-gradient { background: linear-gradient(180deg, #0f172a 0%, #1a2332 50%, #162032 100%); }
    .tooltip { position: relative; }
    .tooltip::after { content: attr(data-tip); position: absolute; bottom: 100%; left: 50%; transform: translateX(-50%); padding: 4px 8px; background: #1e293b; color: white; font-size: 12px; border-radius: 6px; white-space: nowrap; opacity: 0; pointer-events: none; transition: opacity 0.2s; }
    .tooltip:hover::after { opacity: 1; }
    .modal-backdrop { background: rgba(15,23,42,0.5); backdrop-filter: blur(4px); display:none; }
    .modal-backdrop.active { display: flex; }
  </style>
</head>
<body class="min-h-screen bg-slate-50">
  <div class="flex min-h-screen">
    <%- include('../partials/sidebar') %>
    <div class="flex-1 flex flex-col lg:ml-64">
      <%- include('../partials/topbar') %>
      <main class="flex-1 p-4 sm:p-6 fade-in">
        <%- include('../partials/flash') %>

        <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-6">
          <div>
            <h2 class="text-2xl font-bold text-slate-800 flex items-center gap-2">
              <i data-lucide="shield" class="w-7 h-7 text-brand-500"></i> กฎและข้อบังคับ
            </h2>
            <p class="text-slate-500 mt-1">การจัดการกฎ ระเบียบ ข้อบังคับ และบทลงโทษ</p>
          </div>
          <button onclick="document.getElementById('add-modal').classList.add('active')" class="btn btn-primary">
            <i data-lucide="plus" class="w-4 h-4"></i> เพิ่มกฎและข้อบังคับ
          </button>
        </div>

        <!-- Rules Cards -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
          <% rules.forEach(function(r) { %>
          <div class="card p-5">
            <div class="flex items-start justify-between mb-3">
              <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-xl flex items-center justify-center <%= r.is_active ? 'bg-brand-100' : 'bg-slate-100' %>">
                  <i data-lucide="shield" class="w-5 h-5 <%= r.is_active ? 'text-brand-600' : 'text-slate-400' %>"></i>
                </div>
                <div>
                  <h3 class="font-semibold text-slate-800"><%= r.rule_name %></h3>
                  <p class="text-xs text-slate-400"><%= r.is_active ? 'ใช้งาน' : 'ปิดใช้งาน' %> · ใช้ไปแล้ว <%= r.violation_count %> ครั้ง</p>
                </div>
              </div>
              <div class="flex items-center gap-1">
                <button onclick="editRule(<%= r.id %>, '<%= r.rule_name %>', `<%= r.description || '' %>`, <%= r.max_violations %>, `<%= r.penalty || '' %>`, <%= r.is_active ? 'true' : 'false' %>)" class="p-1.5 text-slate-400 hover:text-brand-600 rounded-lg hover:bg-brand-50 transition-all">
                  <i data-lucide="pencil" class="w-4 h-4"></i>
                </button>
                <form method="POST" action="/rules/<%= r.id %>/delete" onsubmit="return confirm('คุณแน่ใจหรือไม่?')" class="inline">
                  <button type="submit" class="p-1.5 text-slate-400 hover:text-red-500 rounded-lg hover:bg-red-50 transition-all">
                    <i data-lucide="trash-2" class="w-4 h-4"></i>
                  </button>
                </form>
              </div>
            </div>
            <p class="text-sm text-slate-500 mb-3"><%= r.description || 'ไม่มีรายละเอียด' %></p>
            <div class="flex items-center gap-4 text-xs">
              <span class="flex items-center gap-1 text-amber-600">
                <i data-lucide="alert-circle" class="w-3.5 h-3.5"></i>
                สูงสุด <%= r.max_violations %> ครั้ง
              </span>
              <% if (r.penalty) { %>
              <span class="flex items-center gap-1 text-red-500">
                <i data-lucide="gavel" class="w-3.5 h-3.5"></i>
                <%= r.penalty %>
              </span>
              <% } %>
            </div>
          </div>
          <% }); %>
        </div>

        <% if (rules.length === 0) { %>
        <div class="card p-12 text-center">
          <i data-lucide="shield-off" class="w-12 h-12 text-slate-300 mx-auto mb-3"></i>
          <p class="text-slate-400">ยังไม่มีกฎในระบบ</p>
        </div>
        <% } %>

        <!-- Add Modal -->
        <div id="add-modal" class="modal-backdrop fixed inset-0 z-50 items-center justify-center">
          <div class="bg-white rounded-2xl shadow-2xl p-6 w-full max-w-lg">
            <h3 class="text-lg font-semibold text-slate-800 mb-4 flex items-center gap-2">
              <i data-lucide="plus" class="w-5 h-5 text-brand-500"></i> เพิ่มกฎใหม่
            </h3>
            <form method="POST" action="/rules" class="space-y-4">
              <div>
                <label class="label">ชื่อกฎ</label>
                <input type="text" name="rule_name" class="input" required placeholder="เช่น จอดรถในที่ห้ามจอด">
              </div>
              <div>
                <label class="label">รายละเอียด</label>
                <textarea name="description" class="input h-20 resize-none" placeholder="อธิบายรายละเอียดกฎ..."></textarea>
              </div>
              <div class="grid grid-cols-2 gap-4">
                <div>
                  <label class="label">จำนวนครั้งสูงสุด</label>
                  <input type="number" name="max_violations" class="input" value="3" min="1" required>
                </div>
                <div>
                  <label class="label">บทลงโทษ</label>
                  <input type="text" name="penalty" class="input" placeholder="เช่น ตักเตือน">
                </div>
              </div>
              <div class="flex gap-3">
                <button type="button" onclick="document.getElementById('add-modal').classList.remove('active')" class="btn btn-secondary flex-1 justify-center">ยกเลิก</button>
                <button type="submit" class="btn btn-primary flex-1 justify-center">บันทึก</button>
              </div>
            </form>
          </div>
        </div>

        <!-- Edit Modal -->
        <div id="edit-modal" class="modal-backdrop fixed inset-0 z-50 items-center justify-center">
          <div class="bg-white rounded-2xl shadow-2xl p-6 w-full max-w-lg">
            <h3 class="text-lg font-semibold text-slate-800 mb-4 flex items-center gap-2">
              <i data-lucide="pencil" class="w-5 h-5 text-brand-500"></i> แก้ไขกฎ
            </h3>
            <form id="edit-form" method="POST" class="space-y-4">
              <div>
                <label class="label">ชื่อกฎ</label>
                <input type="text" name="rule_name" id="edit-rule-name" class="input" required>
              </div>
              <div>
                <label class="label">รายละเอียด</label>
                <textarea name="description" id="edit-description" class="input h-20 resize-none"></textarea>
              </div>
              <div class="grid grid-cols-2 gap-4">
                <div>
                  <label class="label">จำนวนครั้งสูงสุด</label>
                  <input type="number" name="max_violations" id="edit-max" class="input" min="1" required>
                </div>
                <div>
                  <label class="label">บทลงโทษ</label>
                  <input type="text" name="penalty" id="edit-penalty" class="input">
                </div>
              </div>
              <div class="flex items-center gap-2">
                <input type="checkbox" name="is_active" id="edit-active" class="w-4 h-4 rounded text-brand-600">
                <label for="edit-active" class="text-sm text-slate-600">เปิดใช้งาน</label>
              </div>
              <div class="flex gap-3">
                <button type="button" onclick="document.getElementById('edit-modal').classList.remove('active')" class="btn btn-secondary flex-1 justify-center">ยกเลิก</button>
                <button type="submit" class="btn btn-primary flex-1 justify-center">อัปเดต</button>
              </div>
            </form>
          </div>
        </div>

      </main>
    </div>
  </div>
  <script>
    lucide.createIcons();
    function editRule(id, name, desc, max, penalty, active) {
      document.getElementById('edit-form').action = '/rules/' + id + '/update';
      document.getElementById('edit-rule-name').value = name;
      document.getElementById('edit-description').value = desc;
      document.getElementById('edit-max').value = max;
      document.getElementById('edit-penalty').value = penalty;
      document.getElementById('edit-active').checked = active;
      document.getElementById('edit-modal').classList.add('active');
    }
  </script>
  <script src="/js/table-sort.js"></script>
</body>
</html>
