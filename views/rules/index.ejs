<%
  const typeList = Array.isArray(violationTypes) ? violationTypes : [];
  const penaltyTypeList = Array.isArray(penaltyTypes) ? penaltyTypes : [];
  const activeTypeList = typeList.filter(function(type) { return type.is_active; });
  const activePenaltyTypeList = penaltyTypeList.filter(function(type) { return type.is_active; });
  const selectedTab = activeTab === 'types' || activeTab === 'penalties' ? activeTab : 'rules';
  const canCreateRule = activeTypeList.length > 0 && activePenaltyTypeList.length > 0;
%>
<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/output.css">
  <script src="https://unpkg.com/lucide@latest"></script>
  <style>
    .glass { background: rgba(255,255,255,0.7); backdrop-filter: blur(12px); }
    .fade-in { animation: fadeIn 0.3s ease-in; }
    @keyframes fadeIn { from { opacity:0; transform:translateY(8px); } to { opacity:1; transform:translateY(0); } }
    .sidebar-gradient { background: linear-gradient(180deg, #0f172a 0%, #1a2332 50%, #162032 100%); }
    .modal-backdrop { background: rgba(15,23,42,0.6); backdrop-filter: blur(4px); display:none; }
    .modal-backdrop.active { display: flex; animation: backdropIn 0.2s ease; }
    @keyframes backdropIn { from{opacity:0} to{opacity:1} }
    .modal-panel { animation: modalSlideUp 0.25s cubic-bezier(0.16,1,0.3,1); }
    @keyframes modalSlideUp { from{transform:translateY(16px);opacity:0} to{transform:translateY(0);opacity:1} }
    .rules-tab {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      min-height: 42px;
      padding: 10px 14px;
      border-radius: 12px;
      color: #64748b;
      font-size: 14px;
      font-weight: 700;
      transition: all 0.2s;
      flex: 1;
    }
    .rules-tab:hover { background: #f8fafc; color: #334155; }
    .rules-tab[aria-selected="true"] {
      background: #16a34a;
      color: #fff;
      box-shadow: 0 1px 2px rgba(22,163,74,0.25);
    }
    .rules-tab-count {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: 24px;
      height: 22px;
      padding: 0 7px;
      border-radius: 999px;
      background: #e2e8f0;
      color: #475569;
      font-size: 12px;
      font-weight: 800;
    }
    .rules-tab[aria-selected="true"] .rules-tab-count {
      background: rgba(255,255,255,0.22);
      color: #fff;
    }
    .rules-panel { display: none; }
    .rules-panel.active { display: block; }
  </style>
</head>
<body class="min-h-screen bg-slate-50">
  <div class="flex min-h-screen">
    <%- include('../partials/sidebar') %>
    <div class="flex-1 flex flex-col lg:ml-72">
      <%- include('../partials/topbar') %>
      <main class="flex-1 p-4 sm:p-6 fade-in">
        <%- include('../partials/flash') %>

        <div class="flex flex-col gap-2 mb-6">
          <h2 class="text-2xl font-bold text-slate-800 flex items-center gap-2">
            <i data-lucide="shield" class="w-7 h-7 text-brand-500"></i>
            กฎและข้อบังคับ
          </h2>
          <p class="text-slate-500">จัดการกฎ ประเภทความผิด จำนวนครั้งสูงสุด และประเภทบทลงโทษ</p>
        </div>

        <div class="card p-2 mb-6">
          <div class="flex flex-col sm:flex-row gap-2" role="tablist" aria-label="กฎและข้อบังคับ">
            <button type="button"
                    class="rules-tab"
                    data-rules-tab="rules"
                    aria-selected="<%= selectedTab === 'rules' ? 'true' : 'false' %>">
              <i data-lucide="clipboard-list" class="w-4 h-4"></i>
              กฎและข้อบังคับ
              <span class="rules-tab-count"><%= rules.length %></span>
            </button>
            <button type="button"
                    class="rules-tab"
                    data-rules-tab="types"
                    aria-selected="<%= selectedTab === 'types' ? 'true' : 'false' %>">
              <i data-lucide="tags" class="w-4 h-4"></i>
              ประเภทความผิด
              <span class="rules-tab-count"><%= typeList.length %></span>
            </button>
            <button type="button"
                    class="rules-tab"
                    data-rules-tab="penalties"
                    aria-selected="<%= selectedTab === 'penalties' ? 'true' : 'false' %>">
              <i data-lucide="gavel" class="w-4 h-4"></i>
              ประเภทบทลงโทษ
              <span class="rules-tab-count"><%= penaltyTypeList.length %></span>
            </button>
          </div>
        </div>

        <section id="rules-panel" class="rules-panel <%= selectedTab === 'rules' ? 'active' : '' %>" data-rules-panel="rules">
          <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-5">
            <div>
              <h3 class="text-lg font-bold text-slate-800">รายการกฎ</h3>
              <p class="text-sm text-slate-500">เพิ่มกฎใหม่โดยเลือกประเภทความผิดและประเภทบทลงโทษจากรายการที่กำหนดไว้</p>
            </div>
            <button type="button" data-modal-open="add-modal" class="btn btn-primary justify-center" <%= canCreateRule ? '' : 'disabled' %>>
              <i data-lucide="plus" class="w-4 h-4"></i>
              เพิ่มกฎใหม่
            </button>
          </div>

          <% if (!canCreateRule) { %>
          <div class="card p-5 mb-6 border border-amber-100 bg-amber-50">
            <div class="flex items-start gap-3">
              <i data-lucide="alert-circle" class="w-5 h-5 text-amber-600 mt-0.5"></i>
              <div>
                <p class="font-semibold text-amber-800">ยังเพิ่มกฎใหม่ไม่ได้</p>
                <p class="text-sm text-amber-700">
                  <% if (activeTypeList.length === 0 && activePenaltyTypeList.length === 0) { %>
                    กรุณาเพิ่มประเภทความผิดและประเภทบทลงโทษก่อน
                  <% } else if (activeTypeList.length === 0) { %>
                    กรุณาเพิ่มประเภทความผิดก่อน
                  <% } else { %>
                    กรุณาเพิ่มประเภทบทลงโทษก่อน
                  <% } %>
                </p>
              </div>
            </div>
          </div>
          <% } %>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
            <% rules.forEach(function(r) { %>
            <% const maxCount = r.effective_max_violations || r.type_max_violations || r.max_violations || 3; %>
            <% const penaltyText = r.effective_penalty || r.penalty || ''; %>
            <div class="card p-5">
              <div class="flex items-start justify-between gap-3 mb-3">
                <div class="flex items-center gap-3 min-w-0">
                  <div class="w-10 h-10 rounded-xl flex items-center justify-center <%= r.is_active ? 'bg-brand-100' : 'bg-slate-100' %>">
                    <i data-lucide="shield" class="w-5 h-5 <%= r.is_active ? 'text-brand-600' : 'text-slate-400' %>"></i>
                  </div>
                  <div class="min-w-0">
                    <h3 class="font-semibold text-slate-800 break-words"><%= r.rule_name %></h3>
                    <p class="text-xs text-slate-400">
                      <span class="inline-flex items-center gap-1">
                        <span class="w-1.5 h-1.5 rounded-full <%= r.is_active ? 'bg-brand-500' : 'bg-slate-400' %>"></span>
                        <%= r.is_active ? 'เปิดใช้งาน' : 'ปิดใช้งาน' %>
                      </span>
                      · ใช้ไปแล้ว <%= r.violation_count %> ครั้ง
                    </p>
                  </div>
                </div>
                <div class="flex items-center gap-1 flex-shrink-0">
                  <button type="button"
                          class="js-edit-rule p-1.5 text-slate-400 hover:text-brand-600 rounded-lg hover:bg-brand-50 transition-all"
                          data-id="<%= r.id %>"
                          data-rule-name="<%= r.rule_name %>"
                          data-description="<%= r.description || '' %>"
                          data-violation-type-id="<%= r.violation_type_id || '' %>"
                          data-penalty-type-id="<%= r.penalty_type_id || '' %>"
                          data-is-active="<%= r.is_active ? 'true' : 'false' %>"
                          title="แก้ไขกฎ">
                    <i data-lucide="pencil" class="w-4 h-4"></i>
                  </button>
                  <form method="POST"
                        action="/rules/<%= r.id %>/delete"
                        class="inline"
                        data-delete-confirm
                        data-delete-title="ยืนยันการซ่อนกฎ"
                        data-delete-lead="คุณกำลังจะซ่อน:"
                        data-delete-item="กฎและข้อบังคับ: <%= r.rule_name %>"
                        data-delete-detail="กฎจะถูกซ่อนจากการใช้งานใหม่ แต่ประวัติการกระทำผิดที่เคยบันทึกไว้จะยังคงอยู่"
                        data-delete-warning="รายการนี้เป็นการซ่อนเท่านั้น ไม่ลบข้อมูลประวัติเดิม"
                        data-delete-confirm-text="ซ่อนกฎนี้">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <button type="submit" class="p-1.5 text-slate-400 hover:text-red-500 rounded-lg hover:bg-red-50 transition-all" title="ซ่อนกฎนี้">
                      <i data-lucide="eye-off" class="w-4 h-4"></i>
                    </button>
                  </form>
                  <form method="POST"
                        action="/rules/<%= r.id %>/destroy"
                        class="inline"
                        data-delete-confirm
                        data-delete-title="ยืนยันการลบกฎถาวร"
                        data-delete-lead="คุณกำลังจะลบออกจากระบบจริง:"
                        data-delete-item="กฎและข้อบังคับ: <%= r.rule_name %>"
                        data-delete-detail="มีประวัติใช้งานกฎนี้แล้ว <%= r.violation_count %> ครั้ง"
                        data-delete-warning="คำเตือน: การลบถาวรจะลบกฎออกจากฐานข้อมูลจริง และอาจทำให้ประวัติการกระทำผิดที่อ้างอิงกฎนี้ถูกลบตามความสัมพันธ์ของฐานข้อมูล"
                        data-delete-confirm-text="ลบถาวร">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <button type="submit" class="p-1.5 text-slate-400 hover:text-red-600 rounded-lg hover:bg-red-50 transition-all" title="ลบกฎถาวร">
                      <i data-lucide="trash-2" class="w-4 h-4"></i>
                    </button>
                  </form>
                </div>
              </div>
              <p class="text-sm text-slate-500 mb-3 break-words"><%= r.description || 'ไม่มีรายละเอียด' %></p>
              <div class="flex flex-wrap items-center gap-2 mb-4">
                <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-lg bg-sky-50 text-sky-700 text-xs font-semibold">
                  <i data-lucide="tag" class="w-3.5 h-3.5"></i>
                  <%= r.type_name || 'ไม่ระบุประเภทความผิด' %>
                </span>
                <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-lg bg-amber-50 text-amber-700 text-xs font-semibold">
                  <i data-lucide="alert-circle" class="w-3.5 h-3.5"></i>
                  สูงสุด <%= maxCount %> ครั้ง
                </span>
                <% if (penaltyText) { %>
                <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-lg bg-red-50 text-red-600 text-xs font-semibold">
                  <i data-lucide="gavel" class="w-3.5 h-3.5"></i>
                  <%= penaltyText %>
                </span>
                <% } %>
              </div>
              <form method="POST" action="/rules/<%= r.id %>/toggle">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <button type="submit"
                        class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-xs font-semibold border transition-colors <%= r.is_active ? 'bg-amber-50 text-amber-700 border-amber-200 hover:bg-amber-100' : 'bg-brand-50 text-brand-700 border-brand-200 hover:bg-brand-100' %>">
                  <i data-lucide="<%= r.is_active ? 'pause-circle' : 'play-circle' %>" class="w-3.5 h-3.5"></i>
                  <%= r.is_active ? 'ปิดกฎ' : 'เปิดกฎ' %>
                </button>
              </form>
            </div>
            <% }); %>
          </div>

          <% if (rules.length === 0) { %>
          <div class="card p-12 text-center">
            <i data-lucide="shield-off" class="w-12 h-12 text-slate-300 mx-auto mb-3"></i>
            <p class="text-slate-400">ยังไม่มีกฎในระบบ</p>
          </div>
          <% } %>
        </section>

        <section id="types-panel" class="rules-panel <%= selectedTab === 'types' ? 'active' : '' %>" data-rules-panel="types">
          <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-5">
            <div>
              <h3 class="text-lg font-bold text-slate-800">รายการประเภทความผิด</h3>
              <p class="text-sm text-slate-500">จัดการประเภทความผิดและจำนวนครั้งสูงสุดที่ใช้เป็นเกณฑ์เรียกพบ</p>
            </div>
            <button type="button" data-modal-open="add-type-modal" class="btn btn-primary justify-center">
              <i data-lucide="plus" class="w-4 h-4"></i>
              เพิ่มประเภทความผิด
            </button>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <% typeList.forEach(function(type) { %>
            <div class="card p-5">
              <div class="flex items-start justify-between gap-3">
                <div class="min-w-0">
                  <div class="flex flex-wrap items-center gap-2 mb-2">
                    <h4 class="font-semibold text-slate-800 break-words"><%= type.type_name %></h4>
                    <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-semibold <%= type.is_active ? 'bg-emerald-50 text-emerald-700' : 'bg-slate-100 text-slate-500' %>">
                      <i data-lucide="<%= type.is_active ? 'badge-check' : 'badge-x' %>" class="w-3.5 h-3.5"></i>
                      <%= type.is_active ? 'เปิดใช้งาน' : 'ปิดใช้งาน' %>
                    </span>
                  </div>
                  <div class="flex flex-wrap gap-2 text-xs">
                    <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-lg bg-brand-50 text-brand-700 font-semibold">
                      <i data-lucide="hash" class="w-3.5 h-3.5"></i>
                      รหัส <%= type.type_code || '-' %>
                    </span>
                    <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-lg bg-amber-50 text-amber-700 font-semibold">
                      <i data-lucide="alert-circle" class="w-3.5 h-3.5"></i>
                      สูงสุด <%= type.max_violations %> ครั้ง
                    </span>
                    <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-lg bg-slate-100 text-slate-600 font-semibold">
                      <i data-lucide="layers" class="w-3.5 h-3.5"></i>
                      ใช้ในกฎ <%= type.rule_count || 0 %> รายการ
                    </span>
                  </div>
                </div>
                <div class="flex items-center gap-1 flex-shrink-0">
                  <button type="button"
                          class="js-edit-type p-1.5 text-slate-400 hover:text-brand-600 rounded-lg hover:bg-brand-50 transition-all"
                          data-id="<%= type.id %>"
                          data-type-name="<%= type.type_name %>"
                          data-type-code="<%= type.type_code || '' %>"
                          data-max-violations="<%= type.max_violations %>"
                          data-is-active="<%= type.is_active ? 'true' : 'false' %>"
                          title="แก้ไขประเภท">
                    <i data-lucide="pencil" class="w-4 h-4"></i>
                  </button>
                  <form method="POST"
                        action="/rules/types/<%= type.id %>/delete"
                        class="inline"
                        data-delete-confirm
                        data-delete-title="ยืนยันการลบประเภทความผิด"
                        data-delete-lead="คุณกำลังจะลบ:"
                        data-delete-item="ประเภทความผิด: <%= type.type_name %>"
                        data-delete-detail="หากประเภทนี้ถูกใช้งานในกฎอยู่ ระบบจะปิดใช้งานแทนการลบเพื่อรักษาข้อมูลเดิม"
                        data-delete-warning="ตรวจสอบกฎที่ผูกกับประเภทนี้ก่อนดำเนินการ"
                        data-delete-confirm-text="ลบประเภทนี้">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <button type="submit" class="p-1.5 text-slate-400 hover:text-red-600 rounded-lg hover:bg-red-50 transition-all" title="ลบประเภท">
                      <i data-lucide="trash-2" class="w-4 h-4"></i>
                    </button>
                  </form>
                </div>
              </div>
            </div>
            <% }); %>
          </div>

          <% if (typeList.length === 0) { %>
          <div class="card p-12 text-center">
            <i data-lucide="tags" class="w-12 h-12 text-slate-300 mx-auto mb-3"></i>
            <p class="text-slate-400">ยังไม่มีประเภทความผิดในระบบ</p>
          </div>
          <% } %>
        </section>

        <section id="penalties-panel" class="rules-panel <%= selectedTab === 'penalties' ? 'active' : '' %>" data-rules-panel="penalties">
          <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-5">
            <div>
              <h3 class="text-lg font-bold text-slate-800">รายการประเภทบทลงโทษ</h3>
              <p class="text-sm text-slate-500">จัดการตัวเลือกบทลงโทษที่ใช้ตอนเพิ่มหรือแก้ไขกฎ</p>
            </div>
            <button type="button" data-modal-open="add-penalty-modal" class="btn btn-primary justify-center">
              <i data-lucide="plus" class="w-4 h-4"></i>
              เพิ่มประเภทบทลงโทษ
            </button>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <% penaltyTypeList.forEach(function(type) { %>
            <div class="card p-5">
              <div class="flex items-start justify-between gap-3">
                <div class="min-w-0">
                  <div class="flex flex-wrap items-center gap-2 mb-2">
                    <h4 class="font-semibold text-slate-800 break-words"><%= type.penalty_name %></h4>
                    <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-semibold <%= type.is_active ? 'bg-emerald-50 text-emerald-700' : 'bg-slate-100 text-slate-500' %>">
                      <i data-lucide="<%= type.is_active ? 'badge-check' : 'badge-x' %>" class="w-3.5 h-3.5"></i>
                      <%= type.is_active ? 'เปิดใช้งาน' : 'ปิดใช้งาน' %>
                    </span>
                  </div>
                  <p class="text-sm text-slate-500 break-words mb-3"><%= type.description || 'ไม่มีรายละเอียด' %></p>
                  <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-lg bg-slate-100 text-slate-600 text-xs font-semibold">
                    <i data-lucide="layers" class="w-3.5 h-3.5"></i>
                    ใช้ในกฎ <%= type.rule_count || 0 %> รายการ
                  </span>
                </div>
                <div class="flex items-center gap-1 flex-shrink-0">
                  <button type="button"
                          class="js-edit-penalty p-1.5 text-slate-400 hover:text-brand-600 rounded-lg hover:bg-brand-50 transition-all"
                          data-id="<%= type.id %>"
                          data-penalty-name="<%= type.penalty_name %>"
                          data-description="<%= type.description || '' %>"
                          data-is-active="<%= type.is_active ? 'true' : 'false' %>"
                          title="แก้ไขประเภทบทลงโทษ">
                    <i data-lucide="pencil" class="w-4 h-4"></i>
                  </button>
                  <form method="POST"
                        action="/rules/penalties/<%= type.id %>/delete"
                        class="inline"
                        data-delete-confirm
                        data-delete-title="ยืนยันการลบประเภทบทลงโทษ"
                        data-delete-lead="คุณกำลังจะลบ:"
                        data-delete-item="ประเภทบทลงโทษ: <%= type.penalty_name %>"
                        data-delete-detail="หากประเภทนี้ถูกใช้งานในกฎอยู่ ระบบจะปิดใช้งานแทนการลบเพื่อรักษาข้อมูลเดิม"
                        data-delete-warning="ตรวจสอบกฎที่ผูกกับประเภทนี้ก่อนดำเนินการ"
                        data-delete-confirm-text="ลบประเภทนี้">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <button type="submit" class="p-1.5 text-slate-400 hover:text-red-600 rounded-lg hover:bg-red-50 transition-all" title="ลบประเภทบทลงโทษ">
                      <i data-lucide="trash-2" class="w-4 h-4"></i>
                    </button>
                  </form>
                </div>
              </div>
            </div>
            <% }); %>
          </div>

          <% if (penaltyTypeList.length === 0) { %>
          <div class="card p-12 text-center">
            <i data-lucide="gavel" class="w-12 h-12 text-slate-300 mx-auto mb-3"></i>
