  <script>
    function closeModal(id) {
      var modal = document.getElementById(id);
      if (!modal) return;
      modal.classList.remove('active');
      modal.style.display = 'none';
    }

    function openModal(id) {
      var modal = document.getElementById(id);
      if (!modal) return;
      modal.style.display = 'flex';
      modal.classList.add('active');
    }

    function setRulesTab(tabName, updateUrl) {
      var selected = tabName === 'types' || tabName === 'penalties' ? tabName : 'rules';
      document.querySelectorAll('[data-rules-tab]').forEach(function(button) {
        button.setAttribute('aria-selected', button.dataset.rulesTab === selected ? 'true' : 'false');
      });
      document.querySelectorAll('[data-rules-panel]').forEach(function(panel) {
        panel.classList.toggle('active', panel.dataset.rulesPanel === selected);
      });

      if (updateUrl) {
        var url = new URL(window.location.href);
        url.searchParams.set('tab', selected);
        window.history.replaceState({}, '', url);
      }
    }

    window.closeModal = closeModal;
    window.openModal = openModal;

    document.querySelectorAll('[data-rules-tab]').forEach(function(button) {
      button.addEventListener('click', function() {
        setRulesTab(button.dataset.rulesTab, true);
      });
    });

    if (window.lucide) {
      lucide.createIcons();
    }

    document.querySelectorAll('[data-modal-open]').forEach(function(button) {
      button.addEventListener('click', function() {
        if (button.disabled) return;
        openModal(button.dataset.modalOpen);
      });
    });

    document.querySelectorAll('[data-modal-close]').forEach(function(button) {
      button.addEventListener('click', function() {
        closeModal(button.dataset.modalClose);
      });
    });

    document.querySelectorAll('.modal-backdrop').forEach(function(modal) {
      modal.addEventListener('click', function(e) {
        if (e.target === modal) closeModal(modal.id);
      });
    });

    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') {
        document.querySelectorAll('.modal-backdrop.active').forEach(function(modal) {
          closeModal(modal.id);
        });
      }
    });

    document.querySelectorAll('.js-edit-rule').forEach(function(button) {
      button.addEventListener('click', function() {
        document.getElementById('edit-form').action = '/rules/' + button.dataset.id + '/update';
        document.getElementById('edit-rule-name').value = button.dataset.ruleName || '';
        document.getElementById('edit-description').value = button.dataset.description || '';
        document.getElementById('edit-violation-type').value = button.dataset.violationTypeId || '';
        document.getElementById('edit-penalty-type').value = button.dataset.penaltyTypeId || '';
        document.getElementById('edit-active').checked = button.dataset.isActive === 'true';
        openModal('edit-modal');
      });
    });

    document.querySelectorAll('.js-edit-type').forEach(function(button) {
      button.addEventListener('click', function() {
        document.getElementById('edit-type-form').action = '/rules/types/' + button.dataset.id + '/update';
        document.getElementById('edit-type-name').value = button.dataset.typeName || '';
        document.getElementById('edit-type-code').value = button.dataset.typeCode || '';
        document.getElementById('edit-type-max').value = button.dataset.maxViolations || 3;
        document.getElementById('edit-type-active').checked = button.dataset.isActive === 'true';
        openModal('edit-type-modal');
      });
    });

    document.querySelectorAll('.js-edit-penalty').forEach(function(button) {
      button.addEventListener('click', function() {
        document.getElementById('edit-penalty-form').action = '/rules/penalties/' + button.dataset.id + '/update';
        document.getElementById('edit-penalty-name').value = button.dataset.penaltyName || '';
        document.getElementById('edit-penalty-description').value = button.dataset.description || '';
        document.getElementById('edit-penalty-active').checked = button.dataset.isActive === 'true';
        openModal('edit-penalty-modal');
      });
    });

    document.querySelectorAll('input[name="type_code"]').forEach(function(input) {
      input.addEventListener('input', function() {
        input.value = input.value.toUpperCase().replace(/^IR-/, '').replace(/[^A-Z0-9]/g, '');
      });
    });
  </script>
  <script src="/js/table-sort.js"></script>
</body>
