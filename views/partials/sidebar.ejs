<!-- Sidebar Overlay (mobile) -->
<div id="sidebar-overlay" class="fixed inset-0 bg-slate-900/50 backdrop-blur-sm z-30 lg:hidden hidden" onclick="toggleSidebar()"></div>

<aside id="sidebar" class="fixed left-0 top-0 bottom-0 w-72 sidebar-gradient text-white flex flex-col z-40 transition-transform duration-300 -translate-x-full lg:translate-x-0">
  <!-- Logo -->
  <div class="p-6 border-b border-white/10 flex items-center justify-between">
    <div class="flex items-center gap-3">
      <div class="w-10 h-10 bg-brand-500 rounded-xl flex items-center justify-center shadow-lg shadow-brand-500/30">
        <i data-lucide="bike" class="w-5 h-5 text-white"></i>
      </div>
      <div>
        <h1 class="text-lg font-bold tracking-tight">MotoSpace</h1>
        <p class="text-xs text-slate-400">ระบบจัดการรถจักรยานยนต์</p>
      </div>
    </div>
    <!-- Close button (mobile) -->
    <button onclick="toggleSidebar()" class="lg:hidden text-slate-400 hover:text-white p-1">
      <i data-lucide="x" class="w-5 h-5"></i>
    </button>
  </div>

  <!-- Navigation -->
  <nav class="flex-1 p-4 space-y-1 overflow-y-auto">
    <p class="text-xs text-slate-500 uppercase tracking-wider font-semibold px-4 mb-2">เมนูหลัก</p>

    <% if (admin && (admin.role === 'head' || admin.role === 'superadmin')) { %>
    <a href="/dashboard" class="sidebar-link <%= currentPath === '/dashboard' ? 'active' : '' %>" onclick="closeSidebarOnMobile()">
      <i data-lucide="layout-dashboard" class="w-5 h-5"></i>
      แดชบอร์ด
    </a>

    <a href="/registrations" class="sidebar-link <%= currentPath.startsWith('/registrations') && currentPath !== '/registrations/search' && !currentUrl.includes('status=pending') ? 'active' : '' %>" onclick="closeSidebarOnMobile()">
      <i data-lucide="clipboard-list" class="w-5 h-5"></i>
      จัดการทะเบียน
    </a>
    <% } %>

    <!-- ค้นหาด้วยภาพ — opens modal instead of navigating -->
    <button type="button" id="btn-image-search" class="sidebar-link w-full text-left" style="cursor:pointer">
      <i data-lucide="image" class="w-5 h-5"></i>
      ค้นหาด้วยรูปภาพ
    </button>

    <a href="/violations" class="sidebar-link <%= currentPath.startsWith('/violations') ? 'active' : '' %>" onclick="closeSidebarOnMobile()">
      <i data-lucide="alert-triangle" class="w-5 h-5"></i>
      แจ้งการทำผิดกฎ
    </a>

    <% if (admin && (admin.role === 'head' || admin.role === 'superadmin')) { %>
    <p class="text-xs text-slate-500 uppercase tracking-wider font-semibold px-4 mt-6 mb-2">ตรวจสอบ และรายงาน</p>

    <a href="/registrations?status=pending" class="sidebar-link <%= currentUrl.includes('/registrations') && currentUrl.includes('status=pending') ? 'active' : '' %>" onclick="closeSidebarOnMobile()">
      <i data-lucide="file-check" class="w-5 h-5"></i>
      <span class="flex-1">ตรวจสอบการลงทะเบียนใหม่</span>
      <% if (typeof pendingCount !== 'undefined' && pendingCount > 0) { %>
        <span class="bg-red-500 text-white text-[11px] font-bold w-5 h-5 flex items-center justify-center rounded-full ml-auto"><%= pendingCount %></span>
      <% } %>
    </a>

    <a href="/violation-reports" class="sidebar-link <%= currentPath.startsWith('/violation-reports') ? 'active' : '' %>" onclick="closeSidebarOnMobile()">
      <i data-lucide="clipboard-check" class="w-5 h-5"></i>
      <span class="flex-1">ตรวจสอบการกระทำผิดกฎ</span>
      <% if (typeof pendingReportsCount !== 'undefined' && pendingReportsCount > 0) { %>
        <span style="background:#f97316;color:#fff;font-size:11px;font-weight:700;min-width:20px;height:20px;display:flex;align-items:center;justify-content:center;border-radius:9999px;padding:0 4px;flex-shrink:0;"><%= pendingReportsCount %></span>
      <% } %>
    </a>

    <a href="/reports/summons" class="sidebar-link <%= currentPath.startsWith('/reports/summons') ? 'active' : '' %>" onclick="closeSidebarOnMobile()">
      <i data-lucide="user-check" class="w-5 h-5"></i>
      <span class="flex-1">รายงานผู้เข้าข่ายเรียกพบ</span>
      <% if (typeof summonsCandidatesCount !== 'undefined') { %>
        <span style="background:#22c55e;color:#fff;font-size:11px;font-weight:700;min-width:20px;height:20px;display:flex;align-items:center;justify-content:center;border-radius:9999px;padding:0 4px;flex-shrink:0;"><%= summonsCandidatesCount > 99 ? '99+' : summonsCandidatesCount %></span>
      <% } %>
    </a>

    <a href="/reports" class="sidebar-link <%= currentPath === '/reports' ? 'active' : '' %>" onclick="closeSidebarOnMobile()">
      <i data-lucide="pie-chart" class="w-5 h-5"></i>
      รายงานสถิติ
    </a>

    <p class="text-xs text-slate-500 uppercase tracking-wider font-semibold px-4 mt-6 mb-2">จัดการ</p>

    <a href="/rules" class="sidebar-link <%= currentPath.startsWith('/rules') ? 'active' : '' %>" onclick="closeSidebarOnMobile()">
      <i data-lucide="shield" class="w-5 h-5"></i>
      กฎและข้อบังคับ
    </a>

    <a href="/data/import" class="sidebar-link <%= currentPath.startsWith('/data/import') || currentPath === '/data' ? 'active' : '' %>" onclick="closeSidebarOnMobile()">
      <i data-lucide="file-up" class="w-5 h-5"></i>
      นำเข้าข้อมูล
    </a>

    <a href="/data/export" class="sidebar-link <%= currentPath.startsWith('/data/export') ? 'active' : '' %>" onclick="closeSidebarOnMobile()">
      <i data-lucide="file-down" class="w-5 h-5"></i>
      ส่งออกข้อมูล
    </a>
    <% } %>

    <% if (admin && admin.role === 'superadmin') { %>
    <p class="text-xs text-slate-500 uppercase tracking-wider font-semibold px-4 mt-6 mb-2">ระบบ</p>

    <a href="/users" class="sidebar-link <%= currentPath.startsWith('/users') ? 'active' : '' %>" onclick="closeSidebarOnMobile()">
      <i data-lucide="users" class="w-5 h-5"></i>
      จัดการผู้ใช้
    </a>
    <a href="/departments" class="sidebar-link <%= currentPath.startsWith('/departments') ? 'active' : '' %>" onclick="closeSidebarOnMobile()">
      <i data-lucide="building-2" class="w-5 h-5"></i>
      หน่วยงาน
    </a>
    <% } %>
  </nav>

  <!-- User info -->
  <div class="p-4 border-t border-white/10">
    <div class="flex items-center gap-3">
      <div class="w-9 h-9 bg-brand-600 rounded-lg flex items-center justify-center text-sm font-bold">
        <%= admin ? admin.full_name.charAt(0) : '?' %>
      </div>
      <div class="flex-1 min-w-0">
        <p class="text-sm font-medium truncate"><%= admin ? admin.full_name : '' %></p>
        <p class="text-xs text-slate-400">
          <%= admin ? (admin.role === 'superadmin' ? 'ผู้ดูแลระบบ' : admin.role === 'head' ? 'หัวหน้า' : 'เจ้าหน้าที่') : '' %>
        </p>
      </div>
      <a href="/auth/logout" class="text-slate-400 hover:text-white tooltip" data-tip="ออกจากระบบ">
        <i data-lucide="log-out" class="w-4 h-4"></i>
      </a>
    </div>
  </div>
</aside>

<!-- ======================================================
     Delete Confirmation Dialog
     ====================================================== -->
<div id="delete-confirm-modal"
     style="display:none; position:fixed; inset:0; z-index:10000; align-items:center; justify-content:center; padding:1rem;"
     aria-modal="true" role="dialog" aria-labelledby="delete-confirm-title">
  <div id="delete-confirm-backdrop"
       style="position:absolute; inset:0; background:rgba(15,23,42,.72); backdrop-filter:blur(4px);"></div>
  <div style="position:relative; width:100%; max-width:430px; background:#fff; border-radius:16px; box-shadow:0 25px 60px rgba(15,23,42,.28); overflow:hidden;">
    <div style="padding:22px 24px 16px; border-bottom:1px solid #f1f5f9;">
      <div style="display:flex; align-items:flex-start; gap:12px;">
        <div style="width:44px; height:44px; border-radius:14px; background:#fef2f2; color:#dc2626; display:flex; align-items:center; justify-content:center; flex-shrink:0;">
          <i data-lucide="trash-2" style="width:22px; height:22px;"></i>
        </div>
        <div>
          <h2 id="delete-confirm-title" style="font-size:1rem; font-weight:700; color:#0f172a; margin:0;">ยืนยันการลบข้อมูล</h2>
          <p style="font-size:.8rem; color:#64748b; margin:4px 0 0;">โปรดตรวจสอบรายการที่จะลบก่อนดำเนินการ</p>
        </div>
      </div>
    </div>
    <div style="padding:18px 24px;">
      <p id="delete-confirm-lead" style="font-size:.875rem; color:#475569; margin:0 0 10px;">คุณกำลังจะลบ:</p>
      <div style="background:#f8fafc; border:1px solid #e2e8f0; border-radius:12px; padding:12px;">
        <p id="delete-confirm-item" style="font-size:.95rem; font-weight:700; color:#1e293b; margin:0;">รายการนี้</p>
        <p id="delete-confirm-detail" style="font-size:.8rem; color:#64748b; margin:4px 0 0;"></p>
      </div>
      <p id="delete-confirm-warning" style="font-size:.78rem; color:#dc2626; margin:12px 0 0;">
        การลบนี้อาจส่งผลต่อข้อมูลที่เกี่ยวข้อง และไม่ควรทำหากยังไม่แน่ใจ
      </p>
    </div>
    <div style="display:flex; gap:10px; padding:0 24px 22px;">
      <button type="button" id="delete-confirm-cancel"
              style="flex:1; padding:10px 14px; border-radius:10px; border:1px solid #e2e8f0; background:#f8fafc; color:#334155; font-size:.875rem; font-weight:600; cursor:pointer;">
        ยกเลิก
      </button>
      <button type="button" id="delete-confirm-submit"
              style="flex:1; padding:10px 14px; border-radius:10px; border:0; background:#dc2626; color:#fff; font-size:.875rem; font-weight:700; cursor:pointer;">
        ยืนยันลบ
      </button>
    </div>
  </div>
</div>

<!-- ======================================================
     Image Search Modal
     ====================================================== -->
<div id="image-search-modal"
     style="display:none; position:fixed; inset:0; z-index:9999; align-items:center; justify-content:center; padding:1rem;"
     aria-modal="true" role="dialog" aria-labelledby="modal-title">

  <!-- Backdrop -->
  <div id="image-search-backdrop"
       style="position:absolute;inset:0;background:rgba(15,23,42,.7);backdrop-filter:blur(4px);"></div>

  <!-- Modal Panel -->
  <div class="relative w-full max-w-lg bg-white rounded-2xl shadow-2xl overflow-hidden
              transition-all duration-300 scale-95 opacity-0"
       id="image-search-panel">

    <!-- Header -->
    <div class="flex items-center justify-between px-6 py-4 border-b border-slate-100">
      <div class="flex items-center gap-2">
        <div class="w-8 h-8 bg-brand-500/10 rounded-lg flex items-center justify-center">
          <i data-lucide="image" class="w-4 h-4 text-brand-600"></i>
        </div>
        <h2 id="modal-title" class="text-base font-semibold text-slate-800">ค้นหาด้วยรูปภาพ</h2>
      </div>
      <button id="btn-close-image-search"
              class="w-8 h-8 flex items-center justify-center rounded-lg text-slate-400
                     hover:text-slate-700 hover:bg-slate-100 transition-colors"
              aria-label="ปิด">
        <i data-lucide="x" class="w-4 h-4"></i>
      </button>
    </div>

    <!-- Body -->
    <div class="p-6">
      <p class="text-sm text-slate-500 mb-4">อัปโหลดภาพรถจักรยานยนต์หรือป้ายทะเบียน เพื่อค้นหาข้อมูลในระบบ</p>

      <form id="image-search-form" method="POST" action="/registrations/search"
            enctype="multipart/form-data" class="space-y-4">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">

        <!-- Upload Zone -->
        <label id="modal-upload-zone"
               class="relative flex flex-col items-center justify-center gap-3
                      border-2 border-dashed border-slate-300 rounded-xl p-8
                      cursor-pointer transition-all duration-200
                      hover:border-brand-400 hover:bg-brand-50/40
                      group"
               ondragover="modalDragOver(event)"
               ondragleave="modalDragLeave(event)"
               ondrop="modalDrop(event)">

          <!-- Default state -->
          <div id="modal-upload-default" class="flex flex-col items-center gap-2 text-center">
            <div class="w-14 h-14 rounded-2xl bg-slate-100 group-hover:bg-brand-100
                        flex items-center justify-center transition-colors">
              <i data-lucide="upload-cloud" class="w-7 h-7 text-slate-400 group-hover:text-brand-500 transition-colors"></i>
            </div>
            <div>
              <p class="text-sm font-medium text-slate-700">ลากไฟล์มาวาง หรือ คลิกเพื่อเลือก</p>
              <p class="text-xs text-slate-400 mt-0.5">รองรับ JPG, PNG, WebP (ไม่เกิน 10 MB)</p>
            </div>
          </div>

          <!-- Preview -->
          <img id="modal-preview"
               class="hidden max-h-52 w-full object-contain rounded-xl"
               alt="ตัวอย่างรูปภาพที่เลือก">

          <!-- Hidden file input -->
          <input type="file" id="modal-file-input" name="search_image"
                 accept="image/*" class="hidden"
                 onchange="modalFileSelected(this)">
        </label>

        <!-- Action row: camera + change -->
        <div class="flex items-center gap-2">
          <!-- Camera capture -->
          <label class="flex-1 flex items-center justify-center gap-2 py-2 px-3 rounded-xl
                        border border-slate-200 text-sm text-slate-600
                        hover:border-brand-400 hover:text-brand-600 hover:bg-brand-50
                        cursor-pointer transition-colors"
                 title="ถ่ายภาพจากกล้อง">
            <i data-lucide="camera" class="w-4 h-4"></i>
            ถ่ายภาพจากกล้อง
            <input type="file" accept="image/*" capture="environment" class="hidden"
                   onchange="modalCameraSelected(this)">
          </label>

          <!-- Change file (shown after preview) -->
          <button type="button" id="modal-change-btn"
                  onclick="document.getElementById('modal-file-input').click()"
                  class="hidden flex-1 flex items-center justify-center gap-2 py-2 px-3 rounded-xl
                         border border-slate-200 text-sm text-slate-600
                         hover:border-brand-400 hover:text-brand-600 hover:bg-brand-50 transition-colors">
            <i data-lucide="image" class="w-4 h-4"></i>
            เปลี่ยนรูป
          </button>
        </div>

        <!-- Search button -->
        <button type="submit" id="modal-search-btn"
                class="w-full flex items-center justify-center gap-2 py-2.5 px-4
                       bg-brand-500 hover:bg-brand-600 active:scale-[0.98]
                       text-white font-medium rounded-xl shadow-sm
                       transition-all duration-150 disabled:opacity-50 disabled:cursor-not-allowed"
                disabled>
          <i data-lucide="search" class="w-4 h-4"></i>
          ค้นหา
        </button>
      </form>
    </div>
  </div>
</div>

<script>
  /* ── Sidebar helpers ─────────────────────────────────── */
  function toggleSidebar() {
    const sidebar = document.getElementById('sidebar');
    const overlay = document.getElementById('sidebar-overlay');
    sidebar.classList.toggle('-translate-x-full');
    overlay.classList.toggle('hidden');
  }
  function closeSidebarOnMobile() {
    if (window.innerWidth < 1024) {
      const sidebar = document.getElementById('sidebar');
      const overlay = document.getElementById('sidebar-overlay');
      sidebar.classList.add('-translate-x-full');
      overlay.classList.add('hidden');
    }
  }

  /* ── Image Search Modal ──────────────────────────────── */
  function openImageSearchModal() {
    closeSidebarOnMobile();
    var modal = document.getElementById('image-search-modal');
    var panel = document.getElementById('image-search-panel');
    if (!modal) return;
    modal.style.display = 'flex';
    // Trigger animation next frame
    requestAnimationFrame(function() {
      panel.classList.remove('scale-95', 'opacity-0');
      panel.classList.add('scale-100', 'opacity-100');
    });
    document.addEventListener('keydown', handleModalEsc);
  }

  function closeImageSearchModal() {
    var modal = document.getElementById('image-search-modal');
    var panel = document.getElementById('image-search-panel');
    if (!modal) return;
    panel.classList.add('scale-95', 'opacity-0');
    panel.classList.remove('scale-100', 'opacity-100');
    setTimeout(function() {
      modal.style.display = 'none';
      resetModalForm();
    }, 200);
    document.removeEventListener('keydown', handleModalEsc);
  }

  function handleModalEsc(e) {
    if (e.key === 'Escape') closeImageSearchModal();
  }

  function resetModalForm() {
    document.getElementById('modal-file-input').value = '';
    document.getElementById('modal-preview').classList.add('hidden');
    document.getElementById('modal-preview').src = '';
    document.getElementById('modal-upload-default').classList.remove('hidden');
    document.getElementById('modal-change-btn').classList.add('hidden');
    document.getElementById('modal-search-btn').disabled = true;
    const zone = document.getElementById('modal-upload-zone');
    zone.classList.remove('border-brand-400', 'bg-brand-50/40');
    zone.classList.add('border-slate-300');
  }

  function applyModalPreview(file) {
    if (!file || !file.type.startsWith('image/')) return;
    const reader = new FileReader();
    reader.onload = e => {
      const preview = document.getElementById('modal-preview');
      preview.src = e.target.result;
      preview.classList.remove('hidden');
      document.getElementById('modal-upload-default').classList.add('hidden');
      document.getElementById('modal-change-btn').classList.remove('hidden');
      document.getElementById('modal-search-btn').disabled = false;
      // Style zone
      const zone = document.getElementById('modal-upload-zone');
      zone.classList.add('border-brand-400', 'bg-brand-50/20');
      zone.classList.remove('border-slate-300');
    };
    reader.readAsDataURL(file);
  }

  function modalFileSelected(input) {
    if (input.files && input.files[0]) {
      // Copy file to the main form input
      applyModalPreview(input.files[0]);
    }
  }

  function modalCameraSelected(input) {
    if (input.files && input.files[0]) {
      // Transfer file to the named input so it submits with the form
      const dataTransfer = new DataTransfer();
      dataTransfer.items.add(input.files[0]);
      document.getElementById('modal-file-input').files = dataTransfer.files;
      applyModalPreview(input.files[0]);
    }
  }

  /* Drag & Drop */
  function modalDragOver(e) {
    e.preventDefault();
    const zone = document.getElementById('modal-upload-zone');
    zone.classList.add('border-brand-400', 'bg-brand-50/40');
  }
  function modalDragLeave(e) {
    const zone = document.getElementById('modal-upload-zone');
    zone.classList.remove('border-brand-400', 'bg-brand-50/40');
  }
  function modalDrop(e) {
    e.preventDefault();
    modalDragLeave(e);
    const file = e.dataTransfer.files[0];
    if (file && file.type.startsWith('image/')) {
      const dataTransfer = new DataTransfer();
      dataTransfer.items.add(file);
      const input = document.getElementById('modal-file-input');
      input.files = dataTransfer.files;
      applyModalPreview(file);
    }
  }

  /* Click anywhere on zone opens file picker (but not on button/img) */
  var uploadZone = document.getElementById('modal-upload-zone');
  if (uploadZone) {
    uploadZone.addEventListener('click', function(e) {
      if (e.target === uploadZone || e.target.closest('#modal-upload-default')) {
        document.getElementById('modal-file-input').click();
      }
    });
  }

  /* Wire up sidebar button, close button, backdrop via addEventListener */
  document.addEventListener('DOMContentLoaded', function() {});
  (function() {
    var btnOpen = document.getElementById('btn-image-search');
    if (btnOpen) {
      btnOpen.addEventListener('click', function(e) {
        e.stopPropagation();
        openImageSearchModal();
      });
    }
    var btnClose = document.getElementById('btn-close-image-search');
    if (btnClose) {
      btnClose.addEventListener('click', function() { closeImageSearchModal(); });
    }
    var backdrop = document.getElementById('image-search-backdrop');
    if (backdrop) {
      backdrop.addEventListener('click', function() { closeImageSearchModal(); });
    }
  })();

  /* Shared delete confirmation dialog */
  (function() {
    var pendingDeleteForm = null;
    var modal = document.getElementById('delete-confirm-modal');
    var titleEl = document.getElementById('delete-confirm-title');
    var leadEl = document.getElementById('delete-confirm-lead');
    var itemEl = document.getElementById('delete-confirm-item');
    var detailEl = document.getElementById('delete-confirm-detail');
    var warningEl = document.getElementById('delete-confirm-warning');
    var btnCancel = document.getElementById('delete-confirm-cancel');
    var btnSubmit = document.getElementById('delete-confirm-submit');
    var backdrop = document.getElementById('delete-confirm-backdrop');

    function closeDeleteConfirm() {
      pendingDeleteForm = null;
      if (modal) modal.style.display = 'none';
    }

    function openDeleteConfirm(form) {
      pendingDeleteForm = form;
      if (titleEl) titleEl.textContent = form.dataset.deleteTitle || 'ยืนยันการลบข้อมูล';
      if (leadEl) leadEl.textContent = form.dataset.deleteLead || 'คุณกำลังจะลบ:';
      if (itemEl) itemEl.textContent = form.dataset.deleteItem || 'รายการนี้';
      if (detailEl) {
        detailEl.textContent = form.dataset.deleteDetail || '';
        detailEl.style.display = form.dataset.deleteDetail ? 'block' : 'none';
      }
      if (warningEl) warningEl.textContent = form.dataset.deleteWarning || 'การลบนี้อาจส่งผลต่อข้อมูลที่เกี่ยวข้อง และไม่ควรทำหากยังไม่แน่ใจ';
      if (btnSubmit) btnSubmit.textContent = form.dataset.deleteConfirmText || 'ยืนยันลบ';
      if (modal) modal.style.display = 'flex';
    }

    document.addEventListener('submit', function(e) {
      var submittedForm = e.target.closest('form');
      if (!submittedForm) return;
      var action = submittedForm.getAttribute('action') || '';
      var isDeleteForm = submittedForm.hasAttribute('data-delete-confirm') || /\/delete(?:\?|$)/.test(action);
      var form = isDeleteForm ? submittedForm : null;
      if (!form || form.dataset.deleteConfirmed === 'true') return;
      e.preventDefault();
      openDeleteConfirm(form);
    });

    if (btnCancel) btnCancel.addEventListener('click', closeDeleteConfirm);
    if (backdrop) backdrop.addEventListener('click', closeDeleteConfirm);

    if (btnSubmit) {
      btnSubmit.addEventListener('click', function() {
        if (!pendingDeleteForm) return;
        pendingDeleteForm.dataset.deleteConfirmed = 'true';
        HTMLFormElement.prototype.submit.call(pendingDeleteForm);
      });
    }

    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape' && modal && modal.style.display === 'flex') {
        closeDeleteConfirm();
      }
    });
  })();
</script>
