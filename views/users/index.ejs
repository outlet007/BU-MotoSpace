<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/output.css">
  <script src="https://unpkg.com/lucide@latest"></script>
  <style>
    .glass { background: rgba(255,255,255,0.7); backdrop-filter: blur(12px); }
    .fade-in { animation: fadeIn 0.3s ease-in; }
    @keyframes fadeIn { from { opacity:0; transform:translateY(8px); } to { opacity:1; transform:translateY(0); } }
    .sidebar-gradient { background: linear-gradient(180deg, #0f172a 0%, #1a2332 50%, #162032 100%); }
    .tooltip { position: relative; }
    .tooltip::after { content: attr(data-tip); position: absolute; bottom: 100%; left: 50%; transform: translateX(-50%); padding: 4px 8px; background: #1e293b; color: white; font-size: 12px; border-radius: 6px; white-space: nowrap; opacity: 0; pointer-events: none; transition: opacity 0.2s; }
    .tooltip:hover::after { opacity: 1; }
    .modal-backdrop { background: rgba(15,23,42,0.6); backdrop-filter: blur(4px); display:none; }
    .modal-backdrop.active { display: flex; animation: backdropIn 0.2s ease; }
    @keyframes backdropIn { from{opacity:0} to{opacity:1} }
    .modal-panel { animation: modalSlideUp 0.25s cubic-bezier(0.16,1,0.3,1); }
    @keyframes modalSlideUp { from{transform:translateY(16px);opacity:0} to{transform:translateY(0);opacity:1} }
  </style>
</head>
<body class="min-h-screen bg-slate-50">
  <div class="flex min-h-screen">
    <%- include('../partials/sidebar') %>
    <div class="flex-1 flex flex-col lg:ml-64">
      <%- include('../partials/topbar') %>
      <main class="flex-1 p-4 sm:p-6 fade-in">
        <%- include('../partials/flash') %>

        <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-6">
          <div>
            <h2 class="text-2xl font-bold text-slate-800 flex items-center gap-2">
              <i data-lucide="users" class="w-7 h-7 text-brand-500"></i> จัดการผู้ใช้
            </h2>
            <p class="text-slate-500 mt-1">เพิ่ม แก้ไข และจัดการสิทธิ์ผู้ใช้งานในระบบ</p>
          </div>
          <button id="btn-open-add" class="btn btn-primary">
            <i data-lucide="user-plus" class="w-4 h-4"></i> เพิ่มผู้ใช้
          </button>
        </div>

        <!-- Search bar -->
        <div class="card p-4 mb-5">
          <form method="GET" action="/users" class="flex flex-wrap items-end gap-3">
            <!-- ช่องค้นหา -->
            <div class="flex-1 min-w-[200px]">
              <label class="label">ค้นหาผู้ใช้</label>
              <div class="relative">
                <i data-lucide="search" class="w-4 h-4 absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 pointer-events-none"></i>
                <input type="text" name="search" id="user-search-input"
                       value="<%= search %>"
                       class="input" style="padding-left:2.5rem"
                       placeholder="ชื่อ, ชื่อผู้ใช้, อีเมล, เบอร์โทร...">
              </div>
            </div>
            <!-- กรองบทบาท -->
            <div class="min-w-[160px]">
              <label class="label">บทบาท</label>
              <select name="role_filter" id="role-filter-select" class="input">
                <option value="" <%= role_filter === '' ? 'selected' : '' %>>ทุกบทบาท</option>
                <option value="officer"    <%= role_filter === 'officer'    ? 'selected' : '' %>>เจ้าหน้าที่</option>
                <option value="head"       <%= role_filter === 'head'       ? 'selected' : '' %>>หัวหน้า</option>
                <option value="superadmin" <%= role_filter === 'superadmin' ? 'selected' : '' %>>ผู้ดูแลระบบ</option>
              </select>
            </div>
            <!-- กรองสถานะ -->
            <div class="min-w-[140px]">
              <label class="label">สถานะ</label>
              <select name="status_filter" id="status-filter-select" class="input">
                <option value=""         <%= status_filter === ''         ? 'selected' : '' %>>ทุกสถานะ</option>
                <option value="active"   <%= status_filter === 'active'   ? 'selected' : '' %>>ใช้งาน</option>
                <option value="inactive" <%= status_filter === 'inactive' ? 'selected' : '' %>>ระงับ</option>
              </select>
            </div>
            <!-- ปุ่ม -->
            <div class="flex gap-2">
              <button type="submit" id="btn-search-user" class="btn btn-primary">
                <i data-lucide="search" class="w-4 h-4"></i> ค้นหา
              </button>
              <% if (search || role_filter || status_filter) { %>
              <a href="/users" class="btn btn-secondary">
                <i data-lucide="x" class="w-4 h-4"></i> ล้าง
              </a>
              <% } %>
            </div>
          </form>
        </div>

        <!-- Result count -->
        <p class="text-sm text-slate-500 mb-3">
          <% if (search || role_filter || status_filter) { %>
            ค้นพบ <span class="font-semibold text-slate-700"><%= users.length %></span> รายการ
            <% if (search) { %> สำหรับ "<span class="font-semibold text-brand-600"><%= search %></span>"<% } %>
            <% if (role_filter) { %>
              <% const roleLabel = role_filter === 'superadmin' ? 'ผู้ดูแลระบบ' : role_filter === 'head' ? 'หัวหน้า' : 'เจ้าหน้าที่'; %>
              บทบาท: <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-semibold
                <%= role_filter === 'superadmin' ? 'bg-purple-100 text-purple-700' : role_filter === 'head' ? 'bg-blue-100 text-blue-700' : 'bg-green-100 text-green-700' %>">
                <%= roleLabel %>
              </span>
            <% } %>
            <% if (status_filter) { %>
              <% const statusLabel = status_filter === 'active' ? 'ใช้งาน' : 'ระงับ'; %>
              สถานะ: <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-semibold
                <%= status_filter === 'active' ? 'bg-green-100 text-green-700' : 'bg-red-100 text-red-700' %>">
                <%= statusLabel %>
              </span>
            <% } %>
          <% } else { %>
            ผู้ใช้ทั้งหมด <span class="font-semibold text-slate-700"><%= users.length %></span> คน
          <% } %>
        </p>

        <!-- Table -->

        <div class="table-container">
          <table class="data-table">
            <thead>
              <tr>
                <th>ชื่อผู้ใช้</th>
                <th>ชื่อ-นามสกุล</th>
                <th>อีเมล</th>
                <th>เบอร์โทร</th>
                <th>บทบาท</th>
                <th>สถานะ</th>
                <th>วันที่สร้าง</th>
                <th></th>
              </tr>
            </thead>
            <tbody>
              <% users.forEach(function(u) { %>
              <tr class="cursor-pointer hover:bg-brand-50/40 transition-colors"
                  data-uid="<%= u.id %>" data-fullname="<%= u.full_name %>"
                  data-email="<%= (u.email || '') %>" data-phone="<%= (u.phone || '') %>"
                  data-role="<%= u.role %>" data-active="<%= u.is_active ? '1' : '0' %>">
                <td class="text-sm"><%= u.username %></td>
                <td class="font-medium text-slate-800"><%= u.full_name %></td>
                <td class="text-sm text-slate-600">
                  <% if (u.email) { %>
                    <a href="mailto:<%= u.email %>" class="hover:text-brand-600 transition-colors"><%= u.email %></a>
                  <% } else { %>
                    <span class="text-slate-300">—</span>
                  <% } %>
                </td>
                <td class="text-sm text-slate-600">
                  <% if (u.phone) { %>
                    <%= u.phone %>
                  <% } else { %>
                    <span class="text-slate-300">—</span>
                  <% } %>
                </td>
                <td>
                  <span class="badge <%= u.role === 'superadmin' ? 'bg-purple-100 text-purple-700' : u.role === 'head' ? 'bg-blue-100 text-blue-700' : 'badge-success' %>">
                    <%= u.role === 'superadmin' ? 'ผู้ดูแลระบบ' : u.role === 'head' ? 'หัวหน้า' : 'เจ้าหน้าที่' %>
                  </span>
                </td>
                <td>
                  <span class="badge <%= u.is_active ? 'badge-success' : 'badge-danger' %>"><%= u.is_active ? 'ใช้งาน' : 'ระงับ' %></span>
                </td>
                <td class="text-xs text-slate-500"><%= new Date(u.created_at).toLocaleDateString('th-TH') %></td>
                <td data-no-nav>
                  <div class="flex items-center gap-1">
                    <button class="btn-edit-user p-1.5 text-slate-400 hover:text-brand-600 rounded-lg hover:bg-brand-50 transition-all"
                            data-no-nav>
                      <i data-lucide="pencil" class="w-4 h-4"></i>
                    </button>
                    <% if (u.id !== admin.id) { %>
                    <% if (u.is_active) { %>
                    <!-- ปุ่มปิดสถานะ (เปิด confirm dialog) -->
                    <button type="button" class="btn-deactivate-user p-1.5 text-slate-400 hover:text-red-500 rounded-lg hover:bg-red-50 transition-all"
                            data-no-nav data-uid="<%= u.id %>" data-name="<%= u.full_name %>">
                      <i data-lucide="user-x" class="w-4 h-4"></i>
                    </button>
                    <% } else { %>
                    <!-- ปุ่มกู้คืน -->
                    <form method="POST" action="/users/<%= u.id %>/restore" class="inline" data-no-nav>
                      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                      <button type="submit"
                              class="p-1.5 text-slate-400 hover:text-green-600 rounded-lg hover:bg-green-50 transition-all"
                              title="กู้คืนผู้ใช้">
                        <i data-lucide="user-check" class="w-4 h-4"></i>
                      </button>
                    </form>
                    <% } %>
                    <form method="POST"
                          action="/users/<%= u.id %>/delete"
                          class="inline"
                          data-no-nav
                          data-delete-confirm
                          data-delete-title="ยืนยันการลบผู้ใช้ถาวร"
                          data-delete-lead="คุณกำลังจะลบผู้ใช้ออกจากระบบจริง:"
                          data-delete-item="<%= u.full_name %> (@<%= u.username %>)"
                          data-delete-detail="บทบาท: <%= u.role === 'superadmin' ? 'ผู้ดูแลระบบ' : u.role === 'head' ? 'หัวหน้า' : 'เจ้าหน้าที่' %> · สถานะ: <%= u.is_active ? 'ใช้งาน' : 'ระงับ' %>"
                          data-delete-warning="คำเตือน: การลบถาวรจะลบบัญชีผู้ใช้ออกจากฐานข้อมูลจริง และอาจส่งผลต่อประวัติการกระทำที่ผู้ใช้นี้เคยบันทึกหรือรายงานไว้"
                          data-delete-confirm-text="ลบผู้ใช้ถาวร">
                      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                      <button type="submit"
                              class="p-1.5 text-slate-400 hover:text-red-600 rounded-lg hover:bg-red-50 transition-all"
                              title="ลบผู้ใช้ถาวร">
                        <i data-lucide="trash-2" class="w-4 h-4"></i>
                      </button>
                    </form>
                    <% } %>
                  </div>
                </td>
              </tr>
              <% }); %>
            </tbody>
          </table>
        </div>

        <!-- Add User Modal -->
        <div id="add-user-modal" class="modal-backdrop fixed inset-0 z-50 items-center justify-center p-4"
             onclick="if(event.target===this) closeModal('add-user-modal')">
          <div class="modal-panel bg-white rounded-2xl shadow-2xl w-full max-w-md">
            <!-- Header -->
            <div class="flex items-center justify-between px-6 py-4 border-b border-slate-100">
              <div class="flex items-center gap-2">
                <div class="w-8 h-8 bg-brand-500/10 rounded-lg flex items-center justify-center">
                  <i data-lucide="user-plus" class="w-4 h-4 text-brand-600"></i>
                </div>
                <h3 class="text-base font-semibold text-slate-800">เพิ่มผู้ใช้ใหม่</h3>
              </div>
              <button id="btn-close-add"
                      class="w-8 h-8 flex items-center justify-center rounded-lg text-slate-400 hover:text-slate-700 hover:bg-slate-100 transition-colors"
                      aria-label="ปิด">
                <i data-lucide="x" class="w-4 h-4"></i>
              </button>
            </div>
            <!-- Body -->
            <div class="p-6 overflow-y-auto max-h-[80vh]">
              <form method="POST" action="/users" class="space-y-4">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <div>
                  <label class="label">ชื่อผู้ใช้ <span class="text-red-500">*</span></label>
                  <input type="text" name="username" class="input" required placeholder="username">
                </div>
                <div>
                  <label class="label">รหัสผ่าน <span class="text-red-500">*</span></label>
                  <input type="password" name="password" class="input" required placeholder="กรอกรหัสผ่าน">
                </div>
                <div>
                  <label class="label">ชื่อ-นามสกุล <span class="text-red-500">*</span></label>
                  <input type="text" name="full_name" class="input" required placeholder="ชื่อ นามสกุล">
                </div>
                <div>
                  <label class="label">อีเมล</label>
                  <div class="relative">
                    <i data-lucide="mail" class="w-4 h-4 absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 pointer-events-none"></i>
                    <input type="email" name="email" class="input" style="padding-left:2.5rem" placeholder="example@bu.ac.th">
                  </div>
                </div>
                <div>
                  <label class="label">เบอร์โทรศัพท์</label>
                  <div class="relative">
                    <i data-lucide="phone" class="w-4 h-4 absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 pointer-events-none"></i>
                    <input type="tel" name="phone" class="input" style="padding-left:2.5rem" placeholder="08x-xxx-xxxx">
                  </div>
                </div>
                <div>
                  <label class="label">บทบาท <span class="text-red-500">*</span></label>
                  <select name="role" class="input" required>
                    <option value="officer">เจ้าหน้าที่</option>
                    <option value="head">หัวหน้า</option>
                    <option value="superadmin">ผู้ดูแลระบบ</option>
                  </select>
                </div>
                <div class="flex gap-3 pt-1">
                  <button type="button" id="btn-cancel-add" class="btn btn-secondary flex-1 justify-center">ยกเลิก</button>
                  <button type="submit" class="btn btn-primary flex-1 justify-center">เพิ่มผู้ใช้</button>
                </div>
              </form>
            </div>
          </div>
        </div>

        <!-- Edit User Modal -->
        <div id="edit-user-modal" class="modal-backdrop fixed inset-0 z-50 items-center justify-center p-4"
             onclick="if(event.target===this) closeModal('edit-user-modal')">
          <div class="modal-panel bg-white rounded-2xl shadow-2xl w-full max-w-md">
            <!-- Header -->
            <div class="flex items-center justify-between px-6 py-4 border-b border-slate-100">
              <div class="flex items-center gap-2">
                <div class="w-8 h-8 bg-brand-500/10 rounded-lg flex items-center justify-center">
                  <i data-lucide="pencil" class="w-4 h-4 text-brand-600"></i>
                </div>
                <h3 class="text-base font-semibold text-slate-800">แก้ไขผู้ใช้</h3>
              </div>
              <button id="btn-close-edit"
                      class="w-8 h-8 flex items-center justify-center rounded-lg text-slate-400 hover:text-slate-700 hover:bg-slate-100 transition-colors"
                      aria-label="ปิด">
                <i data-lucide="x" class="w-4 h-4"></i>
              </button>
            </div>
            <!-- Body -->
            <div class="p-6 overflow-y-auto max-h-[80vh]">
              <form id="edit-user-form" method="POST" class="space-y-4">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <div>
                  <label class="label">ชื่อ-นามสกุล <span class="text-red-500">*</span></label>
                  <input type="text" name="full_name" id="eu-fullname" class="input" required>
                </div>
                <div>
                  <label class="label">อีเมล</label>
                  <div class="relative">
                    <i data-lucide="mail" class="w-4 h-4 absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 pointer-events-none"></i>
                    <input type="email" name="email" id="eu-email" class="input" style="padding-left:2.5rem" placeholder="example@bu.ac.th">
                  </div>
                </div>
                <div>
                  <label class="label">เบอร์โทรศัพท์</label>
                  <div class="relative">
                    <i data-lucide="phone" class="w-4 h-4 absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 pointer-events-none"></i>
                    <input type="tel" name="phone" id="eu-phone" class="input" style="padding-left:2.5rem" placeholder="08x-xxx-xxxx">
                  </div>
                </div>
                <div>
                  <label class="label">รหัสผ่านใหม่ (เว้นว่างถ้าไม่เปลี่ยน)</label>
                  <input type="password" name="password" class="input" placeholder="กรอกรหัสผ่านใหม่">
                </div>
                <div>
                  <label class="label">บทบาท <span class="text-red-500">*</span></label>
                  <select name="role" id="eu-role" class="input" required>
                    <option value="officer">เจ้าหน้าที่</option>
                    <option value="head">หัวหน้า</option>
                    <option value="superadmin">ผู้ดูแลระบบ</option>
                  </select>
                </div>
                <div class="flex items-center gap-2">
                  <input type="checkbox" name="is_active" id="eu-active" class="w-4 h-4 rounded text-brand-600">
                  <label for="eu-active" class="text-sm text-slate-600">เปิดใช้งาน</label>
                </div>
                <div class="flex gap-3 pt-1">
                  <button type="button" id="btn-cancel-edit" class="btn btn-secondary flex-1 justify-center">ยกเลิก</button>
                  <button type="submit" class="btn btn-primary flex-1 justify-center">อัปเดต</button>
                </div>
              </form>
            </div>
          </div>
        </div>

      </main>
    </div>
  </div>

  <!-- ── DEACTIVATE CONFIRM MODAL ───────────────────────────── -->
  <div id="deactivate-modal"
       style="display:none; position:fixed; inset:0; background:rgba(15,23,42,.6); backdrop-filter:blur(4px); z-index:9999; align-items:center; justify-content:center; padding:1rem;">
    <div style="background:#fff; border-radius:16px; padding:28px; width:100%; max-width:420px; box-shadow:0 25px 60px rgba(0,0,0,.2);">
      <!-- Icon + Title -->
      <div style="display:flex; align-items:center; gap:12px; margin-bottom:16px;">
        <div style="width:48px; height:48px; background:#fef2f2; border-radius:12px; display:flex; align-items:center; justify-content:center; flex-shrink:0; font-size:1.5rem;">
          ⚠️
        </div>
        <div>
          <h3 style="font-size:1rem; font-weight:700; color:#1e293b; margin:0;"> ยืนยันการปิดผู้ใช้</h3>
          <p style="font-size:0.75rem; color:#94a3b8; margin:2px 0 0;">สามารถกู้คืนได้ภายหลัง</p>
        </div>
      </div>
      <!-- Body -->
      <p style="font-size:0.875rem; color:#475569; margin-bottom:8px;">
        คุณต้องการปิดการใช้งาน "<strong id="deactivate-username" style="color:#1e293b;"></strong>" หรือไม่?
      </p>
      <p style="font-size:0.8rem; color:#94a3b8; margin-bottom:24px;">
        <i data-lucide="info" style="width:14px; height:14px; display:inline; vertical-align:middle;"></i>
        ผู้ใช้จะไม่สามารถเข้าสู่ระบบได้จนกว่าจะถูกกู้คืน — ประวัติและข้อมูลยังคงอยู่
      </p>
      <!-- Hidden form -->
      <form id="deactivate-form" method="POST" action="">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <div style="display:flex; gap:12px;">
          <button type="button" id="btn-cancel-deactivate"
                  style="flex:1; padding:10px; background:#f1f5f9; color:#334155; border:1px solid #e2e8f0; border-radius:10px; font-size:0.875rem; font-weight:500; cursor:pointer;">
            ยกเลิก
          </button>
          <button type="submit"
                  style="flex:1; padding:10px; background:#dc2626; color:#fff; border:none; border-radius:10px; font-size:0.875rem; font-weight:600; cursor:pointer; display:flex; align-items:center; justify-content:center; gap:6px;">
            <i data-lucide="user-x" style="width:16px; height:16px;"></i> ปิดการใช้งาน
          </button>
        </div>
      </form>
    </div>
  </div>
  <script>
    lucide.createIcons();

    // ── Modal helpers (ใช้ style.display โดยตรง แทน classList เพื่อความน่าเชื่อถือ) ──
    function openModal(id) {
      var el = document.getElementById(id);
      if (el) el.style.display = 'flex';
    }
    function closeModal(id) {
      var el = document.getElementById(id);
      if (el) el.style.display = 'none';
    }

    // ปิด modal เมื่อคลิก backdrop
    ['add-user-modal', 'edit-user-modal'].forEach(function(id) {
      var el = document.getElementById(id);
      if (!el) return;
      el.addEventListener('click', function(e) {
        if (e.target === el) closeModal(id);
      });
    });

    // ESC key
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') {
        closeModal('add-user-modal');
        closeModal('edit-user-modal');
        closeModal('deactivate-modal');
      }
    });

    // ── เปิด modal เพิ่มผู้ใช้ ──
    var btnOpenAdd = document.getElementById('btn-open-add');
    if (btnOpenAdd) {
      btnOpenAdd.addEventListener('click', function(e) {
        e.stopPropagation();
        openModal('add-user-modal');
      });
    }

    // ── ปุ่มปิด Add modal ──
    ['btn-close-add', 'btn-cancel-add'].forEach(function(bid) {
      var b = document.getElementById(bid);
      if (b) b.addEventListener('click', function() { closeModal('add-user-modal'); });
    });

    // ── ปุ่มปิด Edit modal ──
    ['btn-close-edit', 'btn-cancel-edit'].forEach(function(bid) {
      var b = document.getElementById(bid);
      if (b) b.addEventListener('click', function() { closeModal('edit-user-modal'); });
    });

    // ── ฟังก์ชันเปิด Edit modal พร้อมข้อมูล ──
    function openEditModal(tr) {
      var id       = tr.dataset.uid;
      var fullName = tr.dataset.fullname;
      var email    = tr.dataset.email;
      var phone    = tr.dataset.phone;
      var role     = tr.dataset.role;
      var active   = tr.dataset.active === '1';
      document.getElementById('edit-user-form').action = '/users/' + id + '/update';
      document.getElementById('eu-fullname').value = fullName;
      document.getElementById('eu-email').value    = email;
      document.getElementById('eu-phone').value    = phone;
      document.getElementById('eu-role').value     = role;
      document.getElementById('eu-active').checked = active;
      openModal('edit-user-modal');
    }

    // ── คลิกปุ่มดินสอ (แก้ไข) ──
    document.querySelectorAll('.btn-edit-user').forEach(function(btn) {
      btn.addEventListener('click', function(e) {
        e.stopPropagation();
        var tr = btn.closest('tr');
        if (tr) openEditModal(tr);
      });
    });

    // ── คลิก row ทั้งแถว ──
    document.querySelectorAll('tr[data-uid]').forEach(function(tr) {
      tr.addEventListener('click', function(e) {
        // ไม่ทำงานถ้าคลิกที่ปุ่มหรือ form
        if (e.target.closest('button, a, input, form, [data-no-nav]')) return;
        openEditModal(tr);
      });
    });

    // ── Deactivate confirm modal ──
    var deactivateModal = document.getElementById('deactivate-modal');
    var deactivateForm  = document.getElementById('deactivate-form');
    var deactivateName  = document.getElementById('deactivate-username');

    // ปิด modal เมื่อคลิก backdrop
    if (deactivateModal) {
      deactivateModal.addEventListener('click', function(e) {
        if (e.target === deactivateModal) closeModal('deactivate-modal');
      });
    }

    // ปุ่มยกเลิก
    var btnCancelDeactivate = document.getElementById('btn-cancel-deactivate');
    if (btnCancelDeactivate) {
      btnCancelDeactivate.addEventListener('click', function() { closeModal('deactivate-modal'); });
    }

    // ปุ่มปิดสถานะ (user-x icon)
    document.querySelectorAll('.btn-deactivate-user').forEach(function(btn) {
      btn.addEventListener('click', function(e) {
        e.stopPropagation();
        var uid  = btn.dataset.uid;
        var name = btn.dataset.name;
        if (deactivateName) deactivateName.textContent = name;
        if (deactivateForm) deactivateForm.action = '/users/' + uid + '/deactivate';
        openModal('deactivate-modal');
      });
    });
  </script>
  <script src="/js/table-sort.js"></script>
</body>
</html>
