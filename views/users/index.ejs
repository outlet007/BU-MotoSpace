<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/output.css">
  <script src="https://unpkg.com/lucide@latest"></script>
  <style>
    .glass { background: rgba(255,255,255,0.7); backdrop-filter: blur(12px); }
    .fade-in { animation: fadeIn 0.3s ease-in; }
    @keyframes fadeIn { from { opacity:0; transform:translateY(8px); } to { opacity:1; transform:translateY(0); } }
    .sidebar-gradient { background: linear-gradient(180deg, #0f172a 0%, #1a2332 50%, #162032 100%); }
    .tooltip { position: relative; }
    .tooltip::after { content: attr(data-tip); position: absolute; bottom: 100%; left: 50%; transform: translateX(-50%); padding: 4px 8px; background: #1e293b; color: white; font-size: 12px; border-radius: 6px; white-space: nowrap; opacity: 0; pointer-events: none; transition: opacity 0.2s; }
    .tooltip:hover::after { opacity: 1; }
    .modal-backdrop { background: rgba(15,23,42,0.5); backdrop-filter: blur(4px); display:none; }
    .modal-backdrop.active { display: flex; }
  </style>
</head>
<body class="min-h-screen bg-slate-50">
  <div class="flex min-h-screen">
    <%- include('../partials/sidebar') %>
    <div class="flex-1 flex flex-col lg:ml-64">
      <%- include('../partials/topbar') %>
      <main class="flex-1 p-4 sm:p-6 fade-in">
        <%- include('../partials/flash') %>

        <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-6">
          <div>
            <h2 class="text-2xl font-bold text-slate-800 flex items-center gap-2">
              <i data-lucide="users" class="w-7 h-7 text-brand-500"></i> จัดการผู้ใช้
            </h2>
            <p class="text-slate-500 mt-1">เพิ่ม แก้ไข และจัดการสิทธิ์ผู้ใช้งานในระบบ</p>
          </div>
          <button onclick="document.getElementById('add-user-modal').classList.add('active')" class="btn btn-primary">
            <i data-lucide="user-plus" class="w-4 h-4"></i> เพิ่มผู้ใช้
          </button>
        </div>

        <!-- Table -->
        <div class="table-container">
          <table class="data-table">
            <thead>
              <tr>
                <th>ชื่อผู้ใช้</th>
                <th>ชื่อ-นามสกุล</th>
                <th>บทบาท</th>
                <th>สถานะ</th>
                <th>วันที่สร้าง</th>
                <th></th>
              </tr>
            </thead>
            <tbody>
              <% users.forEach(function(u) { %>
              <tr>
                <td class="text-sm"><%= u.username %></td>
                <td class="font-medium text-slate-800"><%= u.full_name %></td>
                <td>
                  <span class="badge <%= u.role === 'superadmin' ? 'bg-purple-100 text-purple-700' : u.role === 'head' ? 'bg-blue-100 text-blue-700' : 'badge-success' %>">
                    <%= u.role === 'superadmin' ? 'ผู้ดูแลระบบ' : u.role === 'head' ? 'หัวหน้า' : 'เจ้าหน้าที่' %>
                  </span>
                </td>
                <td>
                  <span class="badge <%= u.is_active ? 'badge-success' : 'badge-danger' %>"><%= u.is_active ? 'ใช้งาน' : 'ระงับ' %></span>
                </td>
                <td class="text-xs text-slate-500"><%= new Date(u.created_at).toLocaleDateString('th-TH') %></td>
                <td>
                  <div class="flex items-center gap-1">
                    <button onclick="editUser(<%= u.id %>, '<%= u.full_name %>', '<%= u.role %>', <%= u.is_active ? 'true' : 'false' %>)" class="p-1.5 text-slate-400 hover:text-brand-600 rounded-lg hover:bg-brand-50 transition-all">
                      <i data-lucide="pencil" class="w-4 h-4"></i>
                    </button>
                    <% if (u.id !== admin.id) { %>
                    <form method="POST" action="/users/<%= u.id %>/delete" onsubmit="return confirm('คุณแน่ใจหรือไม่?')" class="inline">
                      <button type="submit" class="p-1.5 text-slate-400 hover:text-red-500 rounded-lg hover:bg-red-50 transition-all">
                        <i data-lucide="trash-2" class="w-4 h-4"></i>
                      </button>
                    </form>
                    <% } %>
                  </div>
                </td>
              </tr>
              <% }); %>
            </tbody>
          </table>
        </div>

        <!-- Add User Modal -->
        <div id="add-user-modal" class="modal-backdrop fixed inset-0 z-50 items-center justify-center">
          <div class="bg-white rounded-2xl shadow-2xl p-6 w-full max-w-md">
            <h3 class="text-lg font-semibold text-slate-800 mb-4 flex items-center gap-2">
              <i data-lucide="user-plus" class="w-5 h-5 text-brand-500"></i> เพิ่มผู้ใช้ใหม่
            </h3>
            <form method="POST" action="/users" class="space-y-4">
              <div>
                <label class="label">ชื่อผู้ใช้</label>
                <input type="text" name="username" class="input" required placeholder="username">
              </div>
              <div>
                <label class="label">รหัสผ่าน</label>
                <input type="password" name="password" class="input" required placeholder="กรอกรหัสผ่าน">
              </div>
              <div>
                <label class="label">ชื่อ-นามสกุล</label>
                <input type="text" name="full_name" class="input" required placeholder="ชื่อ นามสกุล">
              </div>
              <div>
                <label class="label">บทบาท</label>
                <select name="role" class="input" required>
                  <option value="officer">เจ้าหน้าที่</option>
                  <option value="head">หัวหน้า</option>
                  <option value="superadmin">ผู้ดูแลระบบ</option>
                </select>
              </div>
              <div class="flex gap-3">
                <button type="button" onclick="document.getElementById('add-user-modal').classList.remove('active')" class="btn btn-secondary flex-1 justify-center">ยกเลิก</button>
                <button type="submit" class="btn btn-primary flex-1 justify-center">เพิ่มผู้ใช้</button>
              </div>
            </form>
          </div>
        </div>

        <!-- Edit User Modal -->
        <div id="edit-user-modal" class="modal-backdrop fixed inset-0 z-50 items-center justify-center">
          <div class="bg-white rounded-2xl shadow-2xl p-6 w-full max-w-md">
            <h3 class="text-lg font-semibold text-slate-800 mb-4 flex items-center gap-2">
              <i data-lucide="pencil" class="w-5 h-5 text-brand-500"></i> แก้ไขผู้ใช้
            </h3>
            <form id="edit-user-form" method="POST" class="space-y-4">
              <div>
                <label class="label">ชื่อ-นามสกุล</label>
                <input type="text" name="full_name" id="eu-fullname" class="input" required>
              </div>
              <div>
                <label class="label">รหัสผ่านใหม่ (เว้นว่างถ้าไม่เปลี่ยน)</label>
                <input type="password" name="password" class="input" placeholder="กรอกรหัสผ่านใหม่">
              </div>
              <div>
                <label class="label">บทบาท</label>
                <select name="role" id="eu-role" class="input" required>
                  <option value="officer">เจ้าหน้าที่</option>
                  <option value="head">หัวหน้า</option>
                  <option value="superadmin">ผู้ดูแลระบบ</option>
                </select>
              </div>
              <div class="flex items-center gap-2">
                <input type="checkbox" name="is_active" id="eu-active" class="w-4 h-4 rounded text-brand-600">
                <label for="eu-active" class="text-sm text-slate-600">เปิดใช้งาน</label>
              </div>
              <div class="flex gap-3">
                <button type="button" onclick="document.getElementById('edit-user-modal').classList.remove('active')" class="btn btn-secondary flex-1 justify-center">ยกเลิก</button>
                <button type="submit" class="btn btn-primary flex-1 justify-center">อัปเดต</button>
              </div>
            </form>
          </div>
        </div>

      </main>
    </div>
  </div>
  <script>
    lucide.createIcons();
    function editUser(id, fullName, role, active) {
      document.getElementById('edit-user-form').action = '/users/' + id + '/update';
      document.getElementById('eu-fullname').value = fullName;
      document.getElementById('eu-role').value = role;
      document.getElementById('eu-active').checked = active;
      document.getElementById('edit-user-modal').classList.add('active');
    }
  </script>
  <script src="/js/table-sort.js"></script>
</body>
</html>
