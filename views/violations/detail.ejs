<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/output.css">
  <script src="https://unpkg.com/lucide@latest"></script>
  <style>
    .sidebar-gradient { background: linear-gradient(180deg, #0f172a 0%, #1a2332 50%, #162032 100%); }
    .fade-in { animation: fadeIn 0.3s ease-in; }
    @keyframes fadeIn { from { opacity:0; transform:translateY(8px); } to { opacity:1; transform:translateY(0); } }
    ::-webkit-scrollbar { width: 6px; }
    ::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 3px; }
    .info-row { display:flex; justify-content:space-between; align-items:center; padding:12px 0; border-bottom:1px solid #f1f5f9; }
    .info-row:last-child { border-bottom:none; }
    .info-label { font-size:0.8rem; color:#64748b; font-weight:500; min-width:140px; }
    .info-value { font-size:0.875rem; color:#1e293b; font-weight:600; text-align:right; }
    .evidence-img { border-radius:12px; border:1px solid #e2e8f0; cursor:pointer; transition:transform 0.2s; }
    .evidence-img:hover { transform:scale(1.02); }
    .lightbox { display:none; position:fixed; inset:0; background:rgba(15,23,42,0.85); z-index:999; align-items:center; justify-content:center; backdrop-filter:blur(4px); }
    .lightbox.active { display:flex; }
    .lightbox img { max-width:90%; max-height:90%; border-radius:12px; box-shadow:0 25px 50px rgba(0,0,0,0.3); }
    .severity-bar { height:8px; border-radius:999px; overflow:hidden; background:#f1f5f9; }
    .severity-fill { height:100%; border-radius:999px; transition:width 0.4s ease; }
  </style>
</head>
<body class="min-h-screen bg-slate-50">
  <div class="flex min-h-screen">
    <%- include('../partials/sidebar') %>
    <div class="flex-1 flex flex-col lg:ml-72">
      <%- include('../partials/topbar') %>
      <main class="flex-1 p-4 sm:p-6 fade-in">
        <%- include('../partials/flash') %>

        <!-- Back Button -->
        <a href="/violations" class="inline-flex items-center gap-1.5 text-sm text-slate-500 hover:text-brand-600 mb-5 transition-colors">
          <i data-lucide="arrow-left" class="w-4 h-4"></i> กลับไปรายการ
        </a>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
          <!-- Left Column: Main Info -->
          <div class="lg:col-span-2 space-y-6">

            <!-- Violation Summary Card -->
            <div class="card p-6">
              <div class="flex items-center justify-between mb-6">
                <div class="flex items-center gap-4">
                  <div style="width:52px; height:52px; background:#fef2f2; border-radius:14px; display:flex; align-items:center; justify-content:center;">
                    <i data-lucide="shield-alert" class="w-6 h-6 text-red-500"></i>
                  </div>
                  <div>
                    <h2 class="text-xl font-bold text-slate-800">รายการแจ้ง <%= v.incident_code || ('IR-GEN-' + String(v.id).padStart(6, '0')) %></h2>
                    <p class="text-sm text-slate-500"><%= new Date(v.recorded_at).toLocaleDateString('th-TH', {year:'numeric', month:'long', day:'numeric', hour:'2-digit', minute:'2-digit'}) %></p>
                  </div>
                </div>
                <span class="badge badge-danger" style="font-size:0.85rem; padding:6px 14px;"><%= v.rule_name %></span>
              </div>

              <!-- Rule Info -->
              <div style="background:#fef2f2; border:1px solid #fecaca; border-radius:12px; padding:16px; margin-bottom:20px;">
                <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:8px;">
                  <span style="font-size:0.8rem; font-weight:600; color:#991b1b;">กฎที่ฝ่าฝืน: <%= v.rule_name %></span>
                  <span style="font-size:0.75rem; font-weight:700; color:<%= violationCount >= v.max_violations ? '#dc2626' : '#d97706' %>;">
                    ครั้งที่ <%= violationCount %>/<%= v.max_violations %>
                  </span>
                </div>
                <div class="severity-bar">
                  <div class="severity-fill" style="width:<%= Math.min((violationCount/v.max_violations)*100, 100) %>%; background:<%= violationCount >= v.max_violations ? '#ef4444' : '#f59e0b' %>;"></div>
                </div>
                <% if(v.penalty && violationCount >= v.max_violations) { %>
                  <p style="margin-top:10px; font-size:0.8rem; color:#991b1b; font-weight:500;">⚠️ บทลงโทษ: <%= v.penalty %></p>
                <% } %>
              </div>

              <!-- Violation Description -->
              <div style="margin-bottom:20px;">
                <p class="info-label" style="margin-bottom:6px;">รายละเอียดการกระทำผิด</p>
                <div style="background:#f8fafc; border-radius:10px; padding:14px; border:1px solid #e2e8f0;">
                  <p style="font-size:0.875rem; color:#334155; line-height:1.6;"><%= v.description || 'ไม่มีรายละเอียดเพิ่มเติม' %></p>
                </div>
              </div>

              <!-- Recorded By -->
              <div class="info-row" style="border-top:1px solid #f1f5f9; padding-top:16px;">
                <span class="info-label"><i data-lucide="user-check" class="w-3.5 h-3.5" style="display:inline; vertical-align:middle; margin-right:4px;"></i> บันทึกโดย</span>
                <span class="info-value"><%= v.recorded_by_name %></span>
              </div>
              <div class="info-row">
                <span class="info-label"><i data-lucide="calendar" class="w-3.5 h-3.5" style="display:inline; vertical-align:middle; margin-right:4px;"></i> วันที่บันทึก</span>
                <span class="info-value"><%= new Date(v.recorded_at).toLocaleDateString('th-TH', {year:'numeric', month:'long', day:'numeric', hour:'2-digit', minute:'2-digit'}) %></span>
              </div>
            </div>

            <!-- Evidence Photo -->
            <div class="card p-6">
              <h3 style="font-size:0.9rem; font-weight:700; color:#1e293b; margin-bottom:16px; display:flex; align-items:center; gap:8px;">
                <i data-lucide="camera" class="w-4 h-4 text-brand-500"></i> หลักฐาน (ภาพถ่าย)
              </h3>
              <% if(v.evidence_photo) { %>
                <img src="<%= signedUrl(v.evidence_photo) %>" alt="Evidence" class="evidence-img" style="max-width:100%; max-height:400px; object-fit:contain;" onclick="document.getElementById('lightbox').classList.add('active')">
                <p style="font-size:0.75rem; color:#94a3b8; margin-top:8px;">คลิกที่ภาพเพื่อขยาย</p>
              <% } else { %>
                <div style="text-align:center; padding:40px 20px; background:#f8fafc; border-radius:12px; border:1px dashed #e2e8f0;">
                  <i data-lucide="image-off" class="w-10 h-10" style="display:block; margin:0 auto 8px; color:#cbd5e1;"></i>
                  <p style="color:#94a3b8; font-size:0.875rem;">ไม่มีภาพหลักฐาน</p>
                </div>
              <% } %>
            </div>
          </div>

          <!-- Right Column: Registrant Info -->
          <div class="space-y-6">
            <!-- Person Info Card -->
            <div class="card p-5">
              <h3 style="font-size:0.9rem; font-weight:700; color:#1e293b; margin-bottom:16px; display:flex; align-items:center; gap:8px;">
                <i data-lucide="user" class="w-4 h-4 text-brand-500"></i> ข้อมูลผู้ลงทะเบียน
              </h3>

              <div class="info-row">
                <span class="info-label">รหัสประจำตัว</span>
                <span class="info-value" style="font-size:0.8rem;"><%= v.id_number %></span>
              </div>
              <div class="info-row">
                <span class="info-label">ชื่อ-นามสกุล</span>
                <span class="info-value"><%= v.first_name %> <%= v.last_name %></span>
              </div>
              <div class="info-row">
                <span class="info-label">ประเภท</span>
                <span class="info-value">
                  <% if(v.user_type === 'student') { %>
                    <span class="badge badge-info">นักศึกษา</span>
                  <% } else { %>
                    <span class="badge" style="background:#f3e8ff; color:#7c3aed;">บุคลากร</span>
                  <% } %>
                </span>
              </div>
              <div class="info-row">
                <span class="info-label">ป้ายทะเบียน</span>
                <span class="info-value" style="font-size:1rem; color:#0f172a;"><%= v.license_plate %></span>
              </div>
              <div class="info-row">
                <span class="info-label">จังหวัด</span>
                <span class="info-value"><%= v.province %></span>
              </div>
              <% if(v.phone) { %>
              <div class="info-row">
                <span class="info-label">เบอร์โทร</span>
                <span class="info-value"><%= v.phone %></span>
              </div>
              <% } %>

              <a href="/registrations/<%= v.registration_id %>" class="btn btn-secondary w-full justify-center mt-4" style="font-size:0.8rem;">
                <i data-lucide="external-link" class="w-3.5 h-3.5"></i> ดูข้อมูลผู้ลงทะเบียนทั้งหมด
              </a>
            </div>

            <% if (admin && ['head', 'superadmin'].includes(admin.role)) { %>
            <div class="card p-5 space-y-3">
              <h3 style="font-size:0.9rem; font-weight:700; color:#1e293b; margin-bottom:12px; display:flex; align-items:center; gap:8px;">
                <i data-lucide="settings" class="w-4 h-4 text-brand-500"></i> จัดการรายการแจ้ง
              </h3>
              <button type="button" id="btn-open-edit-violation" class="btn btn-primary w-full justify-center">
                <i data-lucide="pencil" class="w-4 h-4"></i>
                แก้ไขรายการแจ้ง
              </button>
              <form method="POST"
                    action="/violations/<%= v.id %>/delete"
                    data-delete-confirm
                    data-delete-item="รายการแจ้ง <%= v.incident_code || ('IR-GEN-' + String(v.id).padStart(6, '0')) %>: <%= v.rule_name %>"
                    data-delete-detail="<%= v.first_name %> <%= v.last_name %> · <%= new Date(v.recorded_at).toLocaleDateString('th-TH') %>"
                    data-delete-warning="เมื่อลบแล้ว รายการแจ้งนี้จะหายไปจากประวัติการกระทำผิด และอาจส่งผลต่อจำนวนครั้งที่ใช้คำนวณการเรียกพบ"
                    data-delete-confirm-text="ลบรายการแจ้ง">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <button type="submit" class="btn btn-secondary w-full justify-center text-red-500 hover:bg-red-50">
                  <i data-lucide="trash-2" class="w-4 h-4"></i>
                  ลบรายการแจ้ง
                </button>
              </form>
            </div>
            <% } %>

            <!-- Vehicle Photos -->
            <div class="card p-5">
              <h3 style="font-size:0.9rem; font-weight:700; color:#1e293b; margin-bottom:12px; display:flex; align-items:center; gap:8px;">
                <i data-lucide="bike" class="w-4 h-4 text-brand-500"></i> รูปภาพรถ
              </h3>
              <div style="display:flex; flex-direction:column; gap:10px;">
                <% if(v.motorcycle_photo) { %>
                <div>
                  <p style="font-size:0.7rem; color:#94a3b8; margin-bottom:4px; text-transform:uppercase; font-weight:600; letter-spacing:0.03em;">รูปรถ</p>
                  <img src="<%= signedUrl(v.motorcycle_photo) %>" alt="Motorcycle" style="width:100%; height:120px; object-fit:cover; border-radius:10px; border:1px solid #e2e8f0;">
                </div>
                <% } %>
                <% if(v.plate_photo) { %>
                <div>
                  <p style="font-size:0.7rem; color:#94a3b8; margin-bottom:4px; text-transform:uppercase; font-weight:600; letter-spacing:0.03em;">ป้ายทะเบียน</p>
                  <img src="<%= signedUrl(v.plate_photo) %>" alt="Plate" style="width:100%; height:120px; object-fit:cover; border-radius:10px; border:1px solid #e2e8f0;">
                </div>
                <% } %>
                <% if(!v.motorcycle_photo && !v.plate_photo) { %>
                <p style="text-align:center; color:#94a3b8; font-size:0.8rem; padding:20px 0;">ไม่มีรูปภาพ</p>
                <% } %>
              </div>
            </div>

          </div>
        </div>

        <% if (admin && ['head', 'superadmin'].includes(admin.role)) { %>
        <div id="violation-edit-modal"
             style="display:none;position:fixed;inset:0;z-index:9999;align-items:center;justify-content:center;padding:1rem;"
             aria-modal="true" role="dialog" aria-labelledby="violation-edit-title">
          <div id="violation-edit-backdrop" style="position:absolute;inset:0;background:rgba(15,23,42,.68);backdrop-filter:blur(4px);"></div>
          <div style="position:relative;width:100%;max-width:540px;background:#fff;border-radius:16px;box-shadow:0 25px 60px rgba(15,23,42,.28);overflow:hidden;">
            <div style="padding:20px 24px 14px;border-bottom:1px solid #f1f5f9;">
              <div class="flex items-start justify-between gap-3">
                <div class="flex items-start gap-3">
                  <div class="w-10 h-10 rounded-xl bg-red-100 text-red-600 flex items-center justify-center flex-shrink-0">
                    <i data-lucide="alert-triangle" class="w-5 h-5"></i>
                  </div>
                  <div>
                    <h3 id="violation-edit-title" class="text-base font-bold text-slate-800">แก้ไขรายการแจ้ง</h3>
                    <p class="text-sm text-slate-500 mt-1"><%= v.first_name %> <%= v.last_name %></p>
                  </div>
                </div>
                <button type="button" data-violation-edit-close class="w-8 h-8 flex items-center justify-center rounded-lg text-slate-400 hover:text-slate-700 hover:bg-slate-100 transition-colors" aria-label="ปิด">
                  <i data-lucide="x" class="w-4 h-4"></i>
                </button>
              </div>
            </div>
            <form method="POST" action="/violations/<%= v.id %>/edit" enctype="multipart/form-data">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <div style="padding:20px 24px;" class="space-y-4">
                <div>
                  <label class="label" for="violation-edit-rule-id">กฎที่กระทำผิด</label>
                  <select id="violation-edit-rule-id" name="rule_id" class="input" required>
                    <% (rules || []).forEach(function(rule) { %>
                      <option value="<%= rule.id %>" <%= Number(rule.id) === Number(v.rule_id) ? 'selected' : '' %>><%= rule.rule_name %><%= rule.is_active ? '' : ' (ปิดใช้งาน)' %></option>
                    <% }); %>
                  </select>
                </div>
                <div>
                  <label class="label" for="violation-edit-recorded-at">วันที่</label>
                  <input id="violation-edit-recorded-at" type="datetime-local" name="recorded_at" class="input" value="<%= v.recorded_at_input || '' %>" required>
                </div>
                <div>
                  <label class="label" for="violation-edit-description">รายการแจ้ง</label>
                  <textarea id="violation-edit-description" name="description" class="input h-24 resize-none" placeholder="รายละเอียดการกระทำผิด"><%= v.description || '' %></textarea>
                </div>
                <div>
                  <label class="label" for="violation-edit-evidence-photo">รูปหลักฐาน</label>
                  <input id="violation-edit-evidence-photo"
                         type="file"
                         name="evidence_photo"
                         class="hidden"
                         accept="image/jpeg,image/png,image/webp">
                  <button id="violation-edit-evidence-button"
                          type="button"
                          class="btn btn-secondary justify-center">
                    <i data-lucide="image-plus" class="w-4 h-4"></i>
                    เปลี่ยนรูปหลักฐาน
                  </button>
                  <p id="violation-edit-evidence-name" class="text-xs text-slate-500 mt-2">ยังไม่ได้เลือกรูปใหม่</p>
                  <p class="text-xs text-slate-400 mt-1">ถ้าไม่เลือกรูปใหม่ ระบบจะใช้หลักฐานเดิม</p>
                  <% if (v.evidence_photo) { %>
                    <div class="mt-2 text-xs text-slate-500">
                      หลักฐานเดิม:
                      <a href="<%= signedUrl(v.evidence_photo) %>"
                         target="_blank"
                         rel="noopener"
                         class="font-semibold text-brand-600 hover:text-brand-700 underline">
                        ดูหลักฐาน
                      </a>
                    </div>
                  <% } %>
                </div>
              </div>
              <div style="display:flex;gap:10px;padding:0 24px 22px;">
                <button type="button" data-violation-edit-close class="btn btn-secondary flex-1 justify-center">ยกเลิก</button>
                <button type="submit" class="btn btn-primary flex-1 justify-center">
                  <i data-lucide="save" class="w-4 h-4"></i>
                  บันทึกการแก้ไข
                </button>
              </div>
            </form>
          </div>
        </div>
        <% } %>

        <!-- Lightbox for evidence photo -->
        <% if(v.evidence_photo) { %>
        <div id="lightbox" class="lightbox" onclick="this.classList.remove('active')">
          <img src="<%= signedUrl(v.evidence_photo) %>" alt="Evidence Full">
        </div>
        <% } %>

      </main>
    </div>
  </div>
  <script>
    lucide.createIcons();

    (function() {
      var modal = document.getElementById('violation-edit-modal');
      var openButton = document.getElementById('btn-open-edit-violation');
      var backdrop = document.getElementById('violation-edit-backdrop');
      var evidenceInput = document.getElementById('violation-edit-evidence-photo');
      var evidenceButton = document.getElementById('violation-edit-evidence-button');
      var evidenceName = document.getElementById('violation-edit-evidence-name');

      function openEdit() {
        if (modal) modal.style.display = 'flex';
      }

      function closeEdit() {
        if (modal) modal.style.display = 'none';
      }

      if (openButton) openButton.addEventListener('click', openEdit);
      if (backdrop) backdrop.addEventListener('click', closeEdit);

      document.querySelectorAll('[data-violation-edit-close]').forEach(function(button) {
        button.addEventListener('click', closeEdit);
      });

      if (evidenceButton && evidenceInput) {
        evidenceButton.addEventListener('click', function() {
          evidenceInput.click();
        });
      }

      if (evidenceInput && evidenceName) {
        evidenceInput.addEventListener('change', function() {
          var file = evidenceInput.files && evidenceInput.files[0];
          evidenceName.textContent = file ? file.name : 'ยังไม่ได้เลือกรูปใหม่';
        });
      }

      document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape' && modal && modal.style.display === 'flex') {
          closeEdit();
        }
      });
    })();
  </script>
</body>
</html>
