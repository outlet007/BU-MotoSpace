<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/output.css">
  <script src="https://unpkg.com/lucide@latest"></script>
  <style>
    .sidebar-gradient { background: linear-gradient(180deg, #0f172a 0%, #1a2332 50%, #162032 100%); }
    .fade-in { animation: fadeIn 0.3s ease-in; }
    @keyframes fadeIn { from { opacity:0; transform:translateY(8px); } to { opacity:1; transform:translateY(0); } }
    ::-webkit-scrollbar { width: 6px; }
    ::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 3px; }
    .upload-zone { border: 2px dashed #cbd5e1; transition: all 0.2s; border-radius: 12px; }
    .upload-zone:hover { border-color: #22c55e; background: #f0fdf4; }
    .reg-info-row { display:flex; justify-content:space-between; padding:8px 0; border-bottom:1px solid #f1f5f9; }
    .reg-info-row:last-child { border-bottom:none; }
    .reg-info-label { font-size:0.8rem; color:#64748b; }
    .reg-info-value { font-size:0.85rem; font-weight:600; color:#1e293b; }
  </style>
</head>
<body class="min-h-screen bg-slate-50">
  <div class="flex min-h-screen">
    <%- include('../partials/sidebar') %>
    <div class="flex-1 flex flex-col lg:ml-64">
      <%- include('../partials/topbar') %>
      <main class="flex-1 p-4 sm:p-6 fade-in">
        <%- include('../partials/flash') %>

        <!-- Back Button -->
        <a href="/violations" class="inline-flex items-center gap-1 text-sm text-slate-500 hover:text-brand-600 mb-4">
          <i data-lucide="arrow-left" class="w-4 h-4"></i> กลับไปหน้าแจ้งการทำผิดกฎ
        </a>

        <div class="max-w-2xl space-y-6">

          <% if (selectedReg) { %>
          <!-- Registrant Info Card -->
          <div class="card p-5">
            <div class="flex items-center gap-4 mb-4">
              <div style="width:44px; height:44px; background:#eff6ff; border-radius:12px; display:flex; align-items:center; justify-content:center;">
                <i data-lucide="<%= selectedReg.user_type === 'student' ? 'graduation-cap' : 'briefcase' %>" class="w-5 h-5 text-brand-600"></i>
              </div>
              <div>
                <h2 class="text-lg font-bold text-slate-800"><%= selectedReg.first_name %> <%= selectedReg.last_name %></h2>
                <p class="text-sm text-slate-500"><%= selectedReg.user_type === 'student' ? 'นักศึกษา' : 'บุคลากร' %> · <%= selectedReg.id_number %></p>
              </div>
            </div>
            <div style="background:#f8fafc; border-radius:10px; padding:12px 16px;">
              <div class="reg-info-row">
                <span class="reg-info-label">ป้ายทะเบียน</span>
                <span class="reg-info-value"><%= selectedReg.license_plate %></span>
              </div>
              <div class="reg-info-row">
                <span class="reg-info-label">จังหวัด</span>
                <span class="reg-info-value"><%= selectedReg.province %></span>
              </div>
              <% if(selectedReg.phone) { %>
              <div class="reg-info-row">
                <span class="reg-info-label">เบอร์โทร</span>
                <span class="reg-info-value"><%= selectedReg.phone %></span>
              </div>
              <% } %>
            </div>
          </div>
          <% } %>

          <!-- Violation Form Card -->
          <div class="card p-6">
            <h2 class="text-lg font-semibold text-slate-800 mb-4 flex items-center gap-2">
              <i data-lucide="shield-alert" class="w-5 h-5 text-orange-500"></i>
              แจ้งการกระทำผิดกฎและข้อบังคับ
            </h2>
            <!-- Workflow notice -->
            <div style="display:flex;align-items:flex-start;gap:10px;background:#fff7ed;border:1px solid #fed7aa;border-radius:10px;padding:12px 14px;margin-bottom:20px;">
              <i data-lucide="info" class="w-4 h-4 text-orange-500 flex-shrink-0 mt-0.5"></i>
              <p style="font-size:0.8rem;color:#9a3412;line-height:1.6;">
                รายการที่แจ้งจะถูกส่งไปยัง <strong>หน้าตรวจสอบการกระทำผิด</strong> เพื่อรอการยืนยันจากผู้ดูแลระบบก่อน
                จึงจะถูกบันทึกลงประวัติของผู้ลงทะเบียน
              </p>
            </div>

            <form method="POST" action="/violations" enctype="multipart/form-data" class="space-y-5">
              <% if (selectedReg) { %>
                <!-- Hidden field with the registration ID -->
                <input type="hidden" name="registration_id" value="<%= selectedReg.id %>">
              <% } else { %>
                <!-- Live search for registrant -->
                <div>
                  <label class="label">ค้นหาผู้ลงทะเบียน</label>
                  <div class="relative" id="live-search-container">
                    <i data-lucide="search" class="w-4 h-4 absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 pointer-events-none"></i>
                    <input type="text" id="reg-search-input" class="input" style="padding-left:2.5rem"
                      placeholder="พิมพ์ชื่อ, รหัส, ป้ายทะเบียน..." autocomplete="off">
                    <div id="reg-search-results" class="hidden absolute z-50 w-full mt-1 bg-white border border-slate-200 rounded-xl shadow-lg max-h-60 overflow-y-auto"></div>
                  </div>
                  <input type="hidden" name="registration_id" id="selected-reg-id" required>
                  <div id="selected-reg-preview" class="hidden mt-2 p-3 bg-slate-50 rounded-xl border border-slate-200 text-sm text-slate-700"></div>
                  <p id="search-hint" class="text-xs text-slate-400 mt-1">พิมพ์อย่างน้อย 1 ตัวอักษร เพื่อค้นหา</p>
                </div>
              <% } %>


              <div>
                <label class="label">กฎที่ฝ่าฝืน</label>
                <select name="rule_id" class="input" required>
                  <option value="">-- เลือกกฎ --</option>
                  <% rules.forEach(function(r) { %>
                  <option value="<%= r.id %>"><%= r.rule_name %> (สูงสุด <%= r.max_violations %> ครั้ง)</option>
                  <% }); %>
                </select>
              </div>

              <div>
                <label class="label">รายละเอียด</label>
                <textarea name="description" class="input h-24 resize-none" placeholder="อธิบายเหตุการณ์โดยย่อ..."></textarea>
              </div>

              <div>
                <label class="label">หลักฐาน (ภาพถ่าย)</label>
                <label class="upload-zone p-6 text-center cursor-pointer block">
                  <i data-lucide="camera" class="w-8 h-8 text-slate-400 mx-auto mb-2"></i>
                  <p class="text-sm text-slate-500">คลิกเพื่อถ่ายรูปหรือเลือกภาพ</p>
                  <input type="file" name="evidence_photo" accept="image/*" capture="environment" class="hidden" onchange="previewEvidence(this)">
                  <img id="evidence-preview" class="max-h-40 rounded-xl mx-auto mt-3 hidden object-cover">
                </label>
              </div>

              <button type="submit" class="btn w-full justify-center" style="background:#ea580c;color:#fff;gap:8px;">
                <i data-lucide="send" class="w-4 h-4"></i> ส่งแจ้งการกระทำผิด (รอการตรวจสอบ)
              </button>
            </form>
          </div>

        </div>
      </main>
    </div>
  </div>
  <script>
    lucide.createIcons();
    function previewEvidence(input) {
      const preview = document.getElementById('evidence-preview');
      if (input.files && input.files[0]) {
        const reader = new FileReader();
        reader.onload = e => { preview.src = e.target.result; preview.classList.remove('hidden'); };
        reader.readAsDataURL(input.files[0]);
      }
    }

    // ---- Live search for registrant (only when no pre-selected reg) ----
    const searchInput = document.getElementById('reg-search-input');
    const resultsBox = document.getElementById('reg-search-results');
    const hiddenId = document.getElementById('selected-reg-id');
    const preview = document.getElementById('selected-reg-preview');

    if (searchInput) {
      let debounceTimer;
      searchInput.addEventListener('input', function() {
        clearTimeout(debounceTimer);
        const q = this.value.trim();
        if (!q) { resultsBox.classList.add('hidden'); resultsBox.innerHTML = ''; return; }
        debounceTimer = setTimeout(() => fetchResults(q), 250);
      });

      searchInput.addEventListener('keydown', function(e) {
        if (e.key === 'Escape') { resultsBox.classList.add('hidden'); }
      });

      document.addEventListener('click', function(e) {
        if (!e.target.closest('#live-search-container')) resultsBox.classList.add('hidden');
      });
    }

    function fetchResults(q) {
      fetch('/registrations/api/search?q=' + encodeURIComponent(q))
        .then(r => r.json())
        .then(data => {
          resultsBox.innerHTML = '';
          if (!data.length) {
            resultsBox.innerHTML = '<div class="px-4 py-3 text-sm text-slate-400">ไม่พบข้อมูล</div>';
          } else {
            data.forEach(r => {
              const item = document.createElement('div');
              item.className = 'px-4 py-3 hover:bg-brand-50 cursor-pointer border-b border-slate-100 last:border-0';
              const typeLabel = r.user_type === 'student' ? 'นักศึกษา' : 'บุคลากร';
              const statusColor = r.status === 'approved' ? '#22c55e' : r.status === 'pending' ? '#f59e0b' : '#ef4444';
              item.innerHTML = `
                <div class="flex items-center justify-between">
                  <div>
                    <p class="font-semibold text-slate-800 text-sm">${r.first_name} ${r.last_name}</p>
                    <p class="text-xs text-slate-500">${r.id_number} · ${r.license_plate} · ${typeLabel}</p>
                  </div>
                  <span style="font-size:10px;padding:2px 8px;border-radius:999px;background:${statusColor}20;color:${statusColor};font-weight:600;">${r.status}</span>
                </div>`;
              item.addEventListener('click', () => selectReg(r));
              resultsBox.appendChild(item);
            });
          }
          resultsBox.classList.remove('hidden');
        })
        .catch(() => { resultsBox.innerHTML = '<div class="px-4 py-3 text-sm text-red-400">เกิดข้อผิดพลาด</div>'; resultsBox.classList.remove('hidden'); });
    }

    function selectReg(r) {
      hiddenId.value = r.id;
      searchInput.value = `${r.first_name} ${r.last_name} (${r.id_number}, ${r.license_plate})`;
      preview.innerHTML = `
        <div class="flex items-center gap-3">
          <div style="width:36px;height:36px;background:#eff6ff;border-radius:8px;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#3b82f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 7H4a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2z"/><circle cx="12" cy="12" r="2"/></svg>
          </div>
          <div>
            <p class="font-semibold text-slate-800">${r.first_name} ${r.last_name}</p>
            <p class="text-xs text-slate-500">${r.id_number} · ${r.license_plate} · ${r.user_type === 'student' ? 'นักศึกษา' : 'บุคลากร'}</p>
          </div>
        </div>`;
      preview.classList.remove('hidden');
      resultsBox.classList.add('hidden');
      document.getElementById('search-hint').classList.add('hidden');
    }
  </script>
</body>
</html>

