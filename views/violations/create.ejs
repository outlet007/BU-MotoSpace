<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/output.css">
  <script src="https://unpkg.com/lucide@latest"></script>
  <style>
    .sidebar-gradient { background: linear-gradient(180deg, #0f172a 0%, #1a2332 50%, #162032 100%); }
    .fade-in { animation: fadeIn 0.3s ease-in; }
    @keyframes fadeIn { from { opacity:0; transform:translateY(8px); } to { opacity:1; transform:translateY(0); } }
    ::-webkit-scrollbar { width: 6px; }
    ::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 3px; }
    .upload-zone { border: 2px dashed #cbd5e1; transition: all 0.2s; border-radius: 12px; }
    .upload-zone:hover { border-color: #22c55e; background: #f0fdf4; }
    .reg-info-row { display:flex; justify-content:space-between; padding:8px 0; border-bottom:1px solid #f1f5f9; }
    .reg-info-row:last-child { border-bottom:none; }
    .reg-info-label { font-size:0.8rem; color:#64748b; }
    .reg-info-value { font-size:0.85rem; font-weight:600; color:#1e293b; }
  </style>
</head>
<body class="min-h-screen bg-slate-50">
  <div class="flex min-h-screen">
    <%- include('../partials/sidebar') %>
    <div class="flex-1 flex flex-col lg:ml-64">
      <%- include('../partials/topbar') %>
      <main class="flex-1 p-4 sm:p-6 fade-in">
        <%- include('../partials/flash') %>

        <!-- Back Button -->
        <% if (selectedReg) { %>
          <a href="/registrations/<%= selectedReg.id %>" class="inline-flex items-center gap-1 text-sm text-slate-500 hover:text-brand-600 mb-4">
            <i data-lucide="arrow-left" class="w-4 h-4"></i> กลับไปรายละเอียดผู้ลงทะเบียน
          </a>
        <% } else { %>
          <a href="/registrations" class="inline-flex items-center gap-1 text-sm text-slate-500 hover:text-brand-600 mb-4">
            <i data-lucide="arrow-left" class="w-4 h-4"></i> กลับไปจัดการทะเบียน
          </a>
        <% } %>

        <div class="max-w-2xl space-y-6">

          <% if (selectedReg) { %>
          <!-- Registrant Info Card -->
          <div class="card p-5">
            <div class="flex items-center gap-4 mb-4">
              <div style="width:44px; height:44px; background:#eff6ff; border-radius:12px; display:flex; align-items:center; justify-content:center;">
                <i data-lucide="<%= selectedReg.user_type === 'student' ? 'graduation-cap' : 'briefcase' %>" class="w-5 h-5 text-brand-600"></i>
              </div>
              <div>
                <h2 class="text-lg font-bold text-slate-800"><%= selectedReg.first_name %> <%= selectedReg.last_name %></h2>
                <p class="text-sm text-slate-500"><%= selectedReg.user_type === 'student' ? 'นักศึกษา' : 'บุคลากร' %> · <%= selectedReg.id_number %></p>
              </div>
            </div>
            <div style="background:#f8fafc; border-radius:10px; padding:12px 16px;">
              <div class="reg-info-row">
                <span class="reg-info-label">ป้ายทะเบียน</span>
                <span class="reg-info-value"><%= selectedReg.license_plate %></span>
              </div>
              <div class="reg-info-row">
                <span class="reg-info-label">จังหวัด</span>
                <span class="reg-info-value"><%= selectedReg.province %></span>
              </div>
              <% if(selectedReg.phone) { %>
              <div class="reg-info-row">
                <span class="reg-info-label">เบอร์โทร</span>
                <span class="reg-info-value"><%= selectedReg.phone %></span>
              </div>
              <% } %>
            </div>
          </div>
          <% } %>

          <!-- Violation Form Card -->
          <div class="card p-6">
            <h2 class="text-lg font-semibold text-slate-800 mb-6 flex items-center gap-2">
              <i data-lucide="shield-alert" class="w-5 h-5 text-red-500"></i>
              บันทึกการกระทำผิดกฎและข้อบังคับ
            </h2>

            <form method="POST" action="/violations" enctype="multipart/form-data" class="space-y-5">
              <% if (selectedReg) { %>
                <!-- Hidden field with the registration ID -->
                <input type="hidden" name="registration_id" value="<%= selectedReg.id %>">
              <% } %>

              <div>
                <label class="label">กฎที่ฝ่าฝืน</label>
                <select name="rule_id" class="input" required>
                  <option value="">-- เลือกกฎ --</option>
                  <% rules.forEach(function(r) { %>
                  <option value="<%= r.id %>"><%= r.rule_name %> (สูงสุด <%= r.max_violations %> ครั้ง)</option>
                  <% }); %>
                </select>
              </div>

              <div>
                <label class="label">รายละเอียด</label>
                <textarea name="description" class="input h-24 resize-none" placeholder="อธิบายเหตุการณ์โดยย่อ..."></textarea>
              </div>

              <div>
                <label class="label">หลักฐาน (ภาพถ่าย)</label>
                <label class="upload-zone p-6 text-center cursor-pointer block">
                  <i data-lucide="camera" class="w-8 h-8 text-slate-400 mx-auto mb-2"></i>
                  <p class="text-sm text-slate-500">คลิกเพื่อถ่ายรูปหรือเลือกภาพ</p>
                  <input type="file" name="evidence_photo" accept="image/*" capture="environment" class="hidden" onchange="previewEvidence(this)">
                  <img id="evidence-preview" class="max-h-40 rounded-xl mx-auto mt-3 hidden object-cover">
                </label>
              </div>

              <button type="submit" class="btn btn-danger w-full justify-center">
                <i data-lucide="save" class="w-4 h-4"></i> บันทึกการกระทำผิดกฎและข้อบังคับ
              </button>
            </form>
          </div>

        </div>
      </main>
    </div>
  </div>
  <script>
    lucide.createIcons();
    function previewEvidence(input) {
      const preview = document.getElementById('evidence-preview');
      if (input.files && input.files[0]) {
        const reader = new FileReader();
        reader.onload = e => { preview.src = e.target.result; preview.classList.remove('hidden'); };
        reader.readAsDataURL(input.files[0]);
      }
    }
  </script>
</body>
</html>
