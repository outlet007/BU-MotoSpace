<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/output.css">
  <script src="https://unpkg.com/lucide@latest"></script>
  <style>
    .glass { background: rgba(255,255,255,0.7); backdrop-filter: blur(12px); }
    .fade-in { animation: fadeIn 0.3s ease-in; }
    @keyframes fadeIn { from { opacity:0; transform:translateY(8px); } to { opacity:1; transform:translateY(0); } }
    .sidebar-gradient { background: linear-gradient(180deg, #0f172a 0%, #1a2332 50%, #162032 100%); }
    .tooltip { position: relative; }
    .tooltip::after { content: attr(data-tip); position: absolute; bottom: 100%; left: 50%; transform: translateX(-50%); padding: 4px 8px; background: #1e293b; color: white; font-size: 12px; border-radius: 6px; white-space: nowrap; opacity: 0; pointer-events: none; transition: opacity 0.2s; }
    .tooltip:hover::after { opacity: 1; }
    .modal-backdrop { background: rgba(15,23,42,0.5); backdrop-filter: blur(4px); display:none; }
    .modal-backdrop.active { display: flex; }
    /* Lightbox */
    .lightbox-overlay { position:fixed; inset:0; z-index:9999; background:rgba(0,0,0,0.85); backdrop-filter:blur(8px); display:none; align-items:center; justify-content:center; cursor:zoom-out; }
    .lightbox-overlay.active { display:flex; animation:lbFadeIn 0.25s ease; }
    .lightbox-overlay img { max-width:90vw; max-height:85vh; object-fit:contain; border-radius:12px; box-shadow:0 25px 60px rgba(0,0,0,0.5); animation:lbZoomIn 0.3s cubic-bezier(0.16,1,0.3,1); }
    .lightbox-caption { position:absolute; bottom:24px; left:50%; transform:translateX(-50%); color:#fff; font-size:14px; background:rgba(0,0,0,0.5); padding:6px 16px; border-radius:8px; white-space:nowrap; }
    .lightbox-close { position:absolute; top:20px; right:24px; color:#fff; background:rgba(255,255,255,0.15); border:none; width:40px; height:40px; border-radius:50%; cursor:pointer; display:flex; align-items:center; justify-content:center; transition:background 0.2s; font-size:20px; }
    .lightbox-close:hover { background:rgba(255,255,255,0.3); }
    .lightbox-nav { position:absolute; top:50%; transform:translateY(-50%); color:#fff; background:rgba(255,255,255,0.15); border:none; width:44px; height:44px; border-radius:50%; cursor:pointer; display:flex; align-items:center; justify-content:center; transition:background 0.2s; font-size:22px; }
    .lightbox-nav:hover { background:rgba(255,255,255,0.3); }
    .lightbox-nav.prev { left:20px; }
    .lightbox-nav.next { right:20px; }
    .lightbox-thumb { cursor:zoom-in; transition:transform 0.2s, box-shadow 0.2s; }
    .lightbox-thumb:hover { transform:scale(1.03); box-shadow:0 4px 20px rgba(0,0,0,0.15); }
    @keyframes lbFadeIn { from{opacity:0} to{opacity:1} }
    @keyframes lbZoomIn { from{transform:scale(0.85);opacity:0} to{transform:scale(1);opacity:1} }
    @media (min-width:1024px) {
      .registration-detail-grid { grid-template-columns:minmax(0,1fr) 24rem; }
    }
  </style>
</head>
<body class="min-h-screen bg-slate-50">
  <div class="flex min-h-screen">
    <%- include('../partials/sidebar') %>
    <div class="flex-1 flex flex-col lg:ml-72">
      <%- include('../partials/topbar') %>
      <main class="flex-1 p-4 sm:p-6 fade-in">
        <%- include('../partials/flash') %>

        <!-- Back -->
        <a href="/registrations" class="inline-flex items-center gap-1 text-sm text-slate-500 hover:text-brand-600 mb-4">
          <i data-lucide="arrow-left" class="w-4 h-4"></i> กลับไปรายการ
        </a>

        <div class="registration-detail-grid grid grid-cols-1 gap-6">
          <!-- Left: Info -->
          <div class="space-y-6">
            <div class="card p-6">
              <div class="flex items-center justify-between mb-6">
                <div class="flex items-center gap-4">
                  <div class="w-14 h-14 bg-brand-100 rounded-2xl flex items-center justify-center">
                    <i data-lucide="<%= reg.user_type === 'student' ? 'graduation-cap' : 'briefcase' %>" class="w-7 h-7 text-brand-600"></i>
                  </div>
                  <div>
                    <h2 class="text-xl font-bold text-slate-800"><%= reg.first_name %> <%= reg.last_name %></h2>
                    <p class="text-sm text-slate-500"><%= reg.user_type === 'student' ? 'นักศึกษา' : 'บุคลากร' %> · <%= reg.id_number %></p>
                  </div>
                </div>
                <span class="badge text-sm px-3 py-1 <%= reg.status === 'approved' ? 'badge-success' : reg.status === 'pending' ? 'badge-warning' : 'badge-danger' %>">
                  <%= reg.status === 'approved' ? 'อนุมัติ' : reg.status === 'pending' ? 'รอดำเนินการ' : 'ปฏิเสธ' %>
                </span>
              </div>

              <div class="grid grid-cols-2 gap-4">
                <div class="p-3 bg-slate-50 rounded-xl">
                  <p class="text-xs text-slate-400 mb-1">เบอร์โทรศัพท์</p>
                  <p class="text-sm font-medium text-slate-700"><%= reg.phone || '-' %></p>
                </div>
                <div class="p-3 bg-slate-50 rounded-xl">
                  <p class="text-xs text-slate-400 mb-1">ป้ายทะเบียน</p>
                  <p class="text-sm font-bold text-slate-800"><%= reg.license_plate %></p>
                </div>
                <div class="p-3 bg-slate-50 rounded-xl">
                  <p class="text-xs text-slate-400 mb-1">จังหวัด</p>
                  <p class="text-sm font-medium text-slate-700"><%= reg.province %></p>
                </div>
                <div class="p-3 bg-slate-50 rounded-xl">
                  <p class="text-xs text-slate-400 mb-1">วันที่ลงทะเบียน</p>
                  <p class="text-sm font-medium text-slate-700"><%= new Date(reg.registered_at).toLocaleDateString('th-TH', {year:'numeric',month:'long',day:'numeric'}) %></p>
                </div>
              </div>
            </div>

            <!-- Photos -->
            <div class="card p-6">
              <h3 class="text-sm font-semibold text-slate-800 mb-4 flex items-center gap-2">
                <i data-lucide="image" class="w-4 h-4 text-brand-500"></i>
                รูปภาพ
              </h3>
              <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                <% if (reg.motorcycle_photo) { %>
                <div>
                  <p class="text-xs text-slate-400 mb-2">รูปรถจักรยานยนต์</p>
                  <img src="<%= signedUrl(reg.motorcycle_photo) %>" alt="Motorcycle" class="w-full h-40 object-cover rounded-xl border border-slate-200 lightbox-thumb" data-lightbox-src="<%= signedUrl(reg.motorcycle_photo) %>" data-lightbox-caption="รูปรถจักรยานยนต์">
                </div>
                <% } %>
                <% if (reg.plate_photo) { %>
                <div>
                  <p class="text-xs text-slate-400 mb-2">รูปป้ายทะเบียน</p>
                  <img src="<%= signedUrl(reg.plate_photo) %>" alt="License Plate" class="w-full h-40 object-cover rounded-xl border border-slate-200 lightbox-thumb" data-lightbox-src="<%= signedUrl(reg.plate_photo) %>" data-lightbox-caption="รูปป้ายทะเบียน">
                </div>
                <% } %>
                <% if (reg.id_card_photo) { %>
                <div>
                  <p class="text-xs text-slate-400 mb-2">รูปบัตรประจำตัว</p>
                  <img src="<%= signedUrl(reg.id_card_photo) %>" alt="ID Card" class="w-full h-40 object-cover rounded-xl border border-slate-200 lightbox-thumb" data-lightbox-src="<%= signedUrl(reg.id_card_photo) %>" data-lightbox-caption="รูปบัตรประจำตัว">
                </div>
                <% } %>
                <% if (!reg.motorcycle_photo && !reg.plate_photo && !reg.id_card_photo) { %>
                <p class="text-sm text-slate-400 col-span-3 text-center py-4">ไม่มีรูปภาพ</p>
                <% } %>
              </div>
            </div>

            <!-- Violations -->
            <div id="violations" class="card p-6">
              <div class="flex items-center justify-between mb-4">
                <h3 class="text-sm font-semibold text-slate-800 flex items-center gap-2">
                  <i data-lucide="alert-triangle" class="w-4 h-4 text-red-500"></i>
                  ประวัติการกระทำผิด
                </h3>
              </div>

              <% if (violationCounts.length > 0) { %>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-3 mb-4">
                <% violationCounts.forEach(function(vc) { %>
                <div class="p-3 rounded-xl border <%= parseInt(vc.cnt) >= parseInt(vc.max_violations) ? 'border-red-200 bg-red-50' : 'border-amber-200 bg-amber-50' %>">
                  <div class="flex justify-between mb-1">
                    <span class="text-xs font-medium <%= parseInt(vc.cnt) >= parseInt(vc.max_violations) ? 'text-red-700' : 'text-amber-700' %>"><%= vc.rule_name %></span>
                    <span class="text-xs font-bold"><%= vc.cnt %>/<%= vc.max_violations %></span>
                  </div>
                  <div class="w-full bg-white/50 rounded-full h-1.5">
                    <div class="<%= parseInt(vc.cnt) >= parseInt(vc.max_violations) ? 'bg-red-500' : 'bg-amber-500' %> h-1.5 rounded-full" style="width:<%= Math.min((parseInt(vc.cnt)/parseInt(vc.max_violations))*100, 100) %>%"></div>
                  </div>
                </div>
                <% }); %>
              </div>
              <% } %>

              <table class="data-table">
                <thead><tr><th style="font-size:12px;">รายการแจ้งเลขที่</th><th>วันที่</th><th>ประเภทความผิด</th><th>กฎที่กระทำผิด</th><th>แจ้งโดย</th><th>ยืนยันโดย</th><th></th></tr></thead>
                <tbody>
                  <% if (violations.length > 0) { %>
                    <% violations.forEach(function(v) { %>
                    <tr class="cursor-pointer hover:bg-brand-50/40 transition-colors"
                        data-href="/violations/<%= v.id %>">
                      <td>
                        <div class="font-semibold text-slate-800" style="font-size:12px;"><%= v.incident_code || ('IR-GEN-' + String(v.id).padStart(6, '0')) %></div>
                      </td>
                      <td class="text-xs whitespace-nowrap"><%= new Date(v.recorded_at).toLocaleDateString('th-TH') %></td>
                      <td><span class="badge badge-danger"><%= v.violation_type_name %></span></td>
                      <td class="text-sm text-slate-600"><%= v.rule_name %></td>
                      <td class="text-xs text-slate-600"><%= v.reported_by_name || v.recorded_by_name %></td>
                      <td class="text-xs font-medium text-brand-600"><%= v.recorded_by_name %></td>
                      <td class="text-right" data-no-nav>
                        <a href="/violations/<%= v.id %>" class="btn btn-secondary btn-sm justify-center whitespace-nowrap">
                          <i data-lucide="eye" class="w-3.5 h-3.5"></i>
                          ดูรายละเอียด
                        </a>
                      </td>
                    </tr>
                    <% }); %>
                  <% } else { %>
                    <tr><td colspan="7" class="text-center text-slate-400 py-6">ไม่มีประวัติการกระทำผิด</td></tr>
                  <% } %>
                </tbody>
              </table>
            </div>

            <!-- Summons Appointments -->
            <div id="summons-history" class="card p-6">
              <div class="flex items-center justify-between mb-4">
                <h3 class="text-sm font-semibold text-slate-800 flex items-center gap-2">
                  <i data-lucide="calendar-check" class="w-4 h-4 text-orange-500"></i>
                  ประวัติการเรียกพบ
                </h3>
              </div>

              <table class="data-table">
                <thead>
                  <tr>
                    <th>วันเวลานัดหมาย</th>
                    <th>รายละเอียดการเรียกพบ</th>
                    <th>เอกสารแนบ</th>
                    <th>บันทึกโดย</th>
                    <th>วันที่บันทึก</th>
                    <th></th>
                  </tr>
                </thead>
                <tbody>
                  <% if (typeof summonsAppointments !== 'undefined' && summonsAppointments.length > 0) { %>
                    <% summonsAppointments.forEach(function(item) { %>
                    <tr class="cursor-pointer hover:bg-brand-50/40 transition-colors"
                        data-summons-detail-row
                        data-appointment-id="<%= item.id %>"
                        data-scheduled-at="<%= item.scheduled_at ? new Date(item.scheduled_at).toLocaleString('th-TH', { year:'numeric', month:'short', day:'numeric', hour:'2-digit', minute:'2-digit' }) : '-' %>"
                        data-scheduled-at-input="<%= item.scheduled_at_input || '' %>"
                        data-note="<%= encodeURIComponent(item.note || '-') %>"
                        data-summoned-by="<%= item.summoned_by_name || '-' %>"
                        data-created-at="<%= item.created_at ? new Date(item.created_at).toLocaleString('th-TH', { year:'numeric', month:'short', day:'numeric', hour:'2-digit', minute:'2-digit' }) : '-' %>"
                        data-document-url="<%= item.written_document ? signedUrl(item.written_document) : '' %>"
                        data-document-name="<%= item.written_document_original_name || 'เอกสารแนบ' %>">
                      <td class="hidden" data-no-nav aria-hidden="true">
                        <button type="button"
                                class="btn btn-secondary btn-sm justify-center whitespace-nowrap"
                                data-summons-detail-open
                                data-scheduled-at="<%= item.scheduled_at ? new Date(item.scheduled_at).toLocaleString('th-TH', { year:'numeric', month:'short', day:'numeric', hour:'2-digit', minute:'2-digit' }) : '-' %>"
                                data-note="<%= encodeURIComponent(item.note || '-') %>"
                                data-summoned-by="<%= item.summoned_by_name || '-' %>"
                                data-created-at="<%= item.created_at ? new Date(item.created_at).toLocaleString('th-TH', { year:'numeric', month:'short', day:'numeric', hour:'2-digit', minute:'2-digit' }) : '-' %>"
                                data-document-url="<%= item.written_document ? signedUrl(item.written_document) : '' %>"
                                data-document-name="<%= item.written_document_original_name || 'เอกสารแนบ' %>">
                          <i data-lucide="eye" class="w-3.5 h-3.5"></i>
                          ดูรายละเอียด
                        </button>
                      </td>
                      <td class="font-medium text-slate-700 whitespace-nowrap" style="font-size:12px;">
                        <%= item.scheduled_at ? new Date(item.scheduled_at).toLocaleString('th-TH', { year:'numeric', month:'short', day:'numeric', hour:'2-digit', minute:'2-digit' }) : '-' %>
                      </td>
                      <td><%= item.note || '-' %></td>
                      <td class="whitespace-nowrap" data-no-nav>
                        <% if (item.written_document) { %>
                          <a href="<%= signedUrl(item.written_document) %>"
                             target="_blank"
                             rel="noopener"
                             download="<%= item.written_document_original_name || 'written-document' %>"
                             class="inline-flex items-center gap-1 text-brand-600 hover:text-brand-700 text-sm font-semibold">
                            <i data-lucide="file-text" class="w-3.5 h-3.5"></i>
                            ดูเอกสาร
                          </a>
                        <% } else { %>
                          -
                        <% } %>
                      </td>
                      <td class="text-xs font-medium text-brand-600"><%= item.summoned_by_name %></td>
                      <td class="text-xs text-slate-500 whitespace-nowrap">
                        <%= item.created_at ? new Date(item.created_at).toLocaleString('th-TH', { year:'numeric', month:'short', day:'numeric', hour:'2-digit', minute:'2-digit' }) : '-' %>
                      </td>
                      <td class="text-right" data-no-nav>
                        <div class="flex flex-wrap justify-end gap-2">
                          <button type="button"
                                  class="btn btn-primary btn-sm justify-center whitespace-nowrap"
                                  data-summons-edit
                                  data-appointment-id="<%= item.id %>"
                                  data-scheduled-at-input="<%= item.scheduled_at_input || '' %>"
                                  data-note="<%= encodeURIComponent(item.note || '') %>"
                                  data-document-url="<%= item.written_document ? signedUrl(item.written_document) : '' %>"
                                  data-document-name="<%= item.written_document_original_name || 'เอกสารแนบ' %>">
                            <i data-lucide="pencil" class="w-3.5 h-3.5"></i>
                            แก้ไข
                          </button>
                          <button type="button"
                                  class="btn btn-secondary btn-sm justify-center whitespace-nowrap"
                                  data-summons-detail-open
                                  data-scheduled-at="<%= item.scheduled_at ? new Date(item.scheduled_at).toLocaleString('th-TH', { year:'numeric', month:'short', day:'numeric', hour:'2-digit', minute:'2-digit' }) : '-' %>"
                                  data-note="<%= encodeURIComponent(item.note || '-') %>"
                                  data-summoned-by="<%= item.summoned_by_name || '-' %>"
                                  data-created-at="<%= item.created_at ? new Date(item.created_at).toLocaleString('th-TH', { year:'numeric', month:'short', day:'numeric', hour:'2-digit', minute:'2-digit' }) : '-' %>"
                                  data-document-url="<%= item.written_document ? signedUrl(item.written_document) : '' %>"
                                  data-document-name="<%= item.written_document_original_name || 'เอกสารแนบ' %>">
                            <i data-lucide="eye" class="w-3.5 h-3.5"></i>
                            ดูรายละเอียด
                          </button>
                        </div>
                      </td>
                    </tr>
                    <% }); %>
                  <% } else { %>
                    <tr><td colspan="6" class="text-center text-slate-400 py-6">ไม่มีประวัติการเรียกพบ</td></tr>
                  <% } %>
                </tbody>
              </table>
            </div>
          </div>

          <!-- Right: Actions -->
          <div class="space-y-4">
            <% if (reg.status === 'pending') { %>
            <div class="card p-5 space-y-3">
              <h3 class="text-sm font-semibold text-slate-800">ดำเนินการ</h3>
              <form method="POST" action="/registrations/<%= reg.id %>/approve">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <button type="submit" class="btn btn-primary w-full justify-center">
                  <i data-lucide="check" class="w-4 h-4"></i> อนุมัติ
                </button>
              </form>
            </div>
            <% } %>

            <div class="card p-5 space-y-3">
              <h3 class="text-sm font-semibold text-slate-800 mb-3">จัดการ</h3>
              <a href="/registrations/<%= reg.id %>/edit" class="btn btn-secondary w-full justify-center">
                <i data-lucide="pencil" class="w-4 h-4"></i> แก้ไขข้อมูล
              </a>
              <form method="POST"
                    action="/registrations/<%= reg.id %>/delete"
                    data-delete-confirm
                    data-delete-item="ทะเบียนรถ: <%= reg.license_plate %>"
                    data-delete-detail="<%= reg.first_name %> <%= reg.last_name %> · <%= reg.id_number %> · <%= reg.user_type === 'student' ? 'นักศึกษา' : 'บุคลากร' %>"
                    data-delete-confirm-text="ลบข้อมูลทะเบียน">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <button type="submit" class="btn btn-secondary w-full justify-center text-red-500 hover:bg-red-50">
                  <i data-lucide="trash-2" class="w-4 h-4"></i> ลบข้อมูล
                </button>
              </form>
            </div>
          </div>
        </div>



      </main>
    </div>
  </div>

  <!-- Summons Detail Modal -->
  <div id="summonsDetailModal"
       style="display:none;position:fixed;inset:0;z-index:9998;align-items:center;justify-content:center;padding:1rem;"
       aria-modal="true" role="dialog" aria-labelledby="summons-detail-title">
    <div data-summons-detail-close style="position:absolute;inset:0;background:rgba(15,23,42,.6);backdrop-filter:blur(4px);"></div>
    <div style="position:relative;width:100%;max-width:520px;background:#fff;border-radius:16px;box-shadow:0 25px 60px rgba(15,23,42,.28);overflow:hidden;">
      <div style="padding:20px 24px 14px;border-bottom:1px solid #f1f5f9;">
        <div class="flex items-start justify-between gap-3">
          <div class="flex items-start gap-3">
            <div class="w-10 h-10 rounded-xl bg-orange-100 text-orange-600 flex items-center justify-center flex-shrink-0">
              <i data-lucide="calendar-check" class="w-5 h-5"></i>
            </div>
            <div>
              <h3 id="summons-detail-title" class="text-base font-bold text-slate-800">รายละเอียดการเรียกพบ</h3>
              <p class="text-sm text-slate-500 mt-1"><%= reg.first_name %> <%= reg.last_name %></p>
            </div>
          </div>
          <button type="button" data-summons-detail-close class="w-8 h-8 flex items-center justify-center rounded-lg text-slate-400 hover:text-slate-700 hover:bg-slate-100 transition-colors" aria-label="ปิด">
            <i data-lucide="x" class="w-4 h-4"></i>
          </button>
        </div>
      </div>
      <div style="padding:20px 24px;" class="space-y-3">
        <div class="p-3 bg-slate-50 rounded-xl">
          <p class="text-xs text-slate-400 mb-1">วันเวลานัดหมาย</p>
          <p id="summons-detail-scheduled-at" class="text-sm font-semibold text-slate-800">-</p>
        </div>
        <div class="p-3 bg-slate-50 rounded-xl">
          <p class="text-xs text-slate-400 mb-1">หมายเหตุ</p>
          <p id="summons-detail-note" class="text-sm text-slate-700 whitespace-pre-wrap">-</p>
        </div>
        <div class="p-3 bg-slate-50 rounded-xl">
          <p class="text-xs text-slate-400 mb-1">เอกสารแนบ</p>
          <a id="summons-detail-document"
             href="#"
             target="_blank"
             rel="noopener"
             class="inline-flex items-center gap-1 text-sm font-semibold text-brand-600 hover:text-brand-700 underline">
            -
          </a>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
          <div class="p-3 bg-slate-50 rounded-xl">
            <p class="text-xs text-slate-400 mb-1">บันทึกโดย</p>
            <p id="summons-detail-by" class="text-sm font-semibold text-brand-600">-</p>
          </div>
          <div class="p-3 bg-slate-50 rounded-xl">
            <p class="text-xs text-slate-400 mb-1">วันที่บันทึก</p>
            <p id="summons-detail-created-at" class="text-sm text-slate-700">-</p>
          </div>
        </div>
      </div>
      <div style="display:flex;justify-content:flex-end;padding:0 24px 22px;">
        <button type="button" data-summons-detail-close class="btn btn-secondary justify-center">ปิด</button>
      </div>
    </div>
  </div>

  <!-- Summons Edit Modal -->
  <div id="summonsEditModal"
       style="display:none;position:fixed;inset:0;z-index:9999;align-items:center;justify-content:center;padding:1rem;"
       aria-modal="true" role="dialog" aria-labelledby="summons-edit-title">
    <div data-summons-edit-close style="position:absolute;inset:0;background:rgba(15,23,42,.68);backdrop-filter:blur(4px);"></div>
    <div style="position:relative;width:100%;max-width:520px;background:#fff;border-radius:16px;box-shadow:0 25px 60px rgba(15,23,42,.28);overflow:hidden;">
      <div style="padding:20px 24px 14px;border-bottom:1px solid #f1f5f9;">
        <div class="flex items-start justify-between gap-3">
          <div class="flex items-start gap-3">
            <div class="w-10 h-10 rounded-xl bg-brand-100 text-brand-600 flex items-center justify-center flex-shrink-0">
              <i data-lucide="pencil" class="w-5 h-5"></i>
            </div>
            <div>
              <h3 id="summons-edit-title" class="text-base font-bold text-slate-800">แก้ไขรายละเอียดการเรียกพบ</h3>
              <p class="text-sm text-slate-500 mt-1"><%= reg.first_name %> <%= reg.last_name %></p>
            </div>
          </div>
          <button type="button" data-summons-edit-close class="w-8 h-8 flex items-center justify-center rounded-lg text-slate-400 hover:text-slate-700 hover:bg-slate-100 transition-colors" aria-label="ปิด">
            <i data-lucide="x" class="w-4 h-4"></i>
          </button>
        </div>
      </div>
      <form id="summonsEditForm" method="POST" action="" enctype="multipart/form-data">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <div style="padding:20px 24px;" class="space-y-4">
          <div>
            <label class="label" for="summons-edit-scheduled-at">วันเวลานัดหมาย</label>
            <input id="summons-edit-scheduled-at" type="datetime-local" name="scheduled_at" class="input" required>
          </div>
          <div>
            <label class="label" for="summons-edit-note">รายละเอียดการเรียกพบ</label>
            <textarea id="summons-edit-note" name="note" class="input h-24 resize-none" placeholder="เช่น สถานที่นัดหมาย ผู้รับผิดชอบ หรือรายละเอียดเพิ่มเติม"></textarea>
          </div>
          <div>
            <label class="label" for="summons-edit-written-document">เอกสารแนบ</label>
            <input id="summons-edit-written-document"
                   type="file"
                   name="written_document"
                   class="hidden"
                   accept=".pdf,.doc,.docx,image/jpeg,image/png,image/webp">
            <button id="summons-edit-written-document-button"
                    type="button"
                    class="btn btn-secondary justify-center">
              <i data-lucide="paperclip" class="w-4 h-4"></i>
              เปลี่ยนไฟล์เอกสาร
            </button>
            <p id="summons-edit-written-document-name" class="text-xs text-slate-500 mt-2">ยังไม่ได้เลือกไฟล์ใหม่</p>
            <p class="text-xs text-slate-400 mt-1">ถ้าไม่เลือกไฟล์ใหม่ ระบบจะใช้เอกสารเดิม</p>
            <div id="summons-edit-existing-document" class="mt-2 text-xs text-slate-500" style="display:none;">
              เอกสารเดิม:
              <a id="summons-edit-existing-document-link"
                 href="#"
                 target="_blank"
                 rel="noopener"
                 class="font-semibold text-brand-600 hover:text-brand-700 underline">
                เอกสารแนบ
              </a>
            </div>
          </div>
        </div>
        <div style="display:flex;gap:10px;padding:0 24px 22px;">
          <button type="button" data-summons-edit-close class="btn btn-secondary flex-1 justify-center">ยกเลิก</button>
          <button type="submit" class="btn btn-primary flex-1 justify-center">
            <i data-lucide="save" class="w-4 h-4"></i>
            บันทึกการแก้ไข
          </button>
        </div>
      </form>
    </div>
  </div>

  <!-- Lightbox Modal -->
  <div id="lightboxOverlay" class="lightbox-overlay">
    <button type="button" class="lightbox-close" title="ปิด">✕</button>
    <button type="button" class="lightbox-nav prev" title="ก่อนหน้า">❮</button>
    <img id="lightboxImg" src="" alt="">
    <button type="button" class="lightbox-nav next" title="ถัดไป">❯</button>
    <div id="lightboxCaption" class="lightbox-caption"></div>
  </div>

  <script>lucide.createIcons();</script>
  <script>
    document.addEventListener('click', function(e) {
      var row = e.target.closest('tr[data-href]');
      if (!row) return;
      if (e.target.closest('button, a, input, select, textarea, form, [data-no-nav]')) return;
      window.location.href = row.dataset.href;
    });

    (function() {
      var modal = document.getElementById('summonsDetailModal');
      var scheduledEl = document.getElementById('summons-detail-scheduled-at');
      var noteEl = document.getElementById('summons-detail-note');
      var byEl = document.getElementById('summons-detail-by');
      var createdAtEl = document.getElementById('summons-detail-created-at');
      var documentLink = document.getElementById('summons-detail-document');
      var editModal = document.getElementById('summonsEditModal');
      var editForm = document.getElementById('summonsEditForm');
      var editScheduledInput = document.getElementById('summons-edit-scheduled-at');
      var editNoteInput = document.getElementById('summons-edit-note');
      var editDocumentInput = document.getElementById('summons-edit-written-document');
      var editDocumentButton = document.getElementById('summons-edit-written-document-button');
      var editDocumentName = document.getElementById('summons-edit-written-document-name');
      var editExistingDocument = document.getElementById('summons-edit-existing-document');
      var editExistingDocumentLink = document.getElementById('summons-edit-existing-document-link');

      function openDetail(button) {
        if (!modal) return;
        if (scheduledEl) scheduledEl.textContent = button.dataset.scheduledAt || '-';
        if (noteEl) noteEl.textContent = decodeURIComponent(button.dataset.note || '-');
        if (byEl) byEl.textContent = button.dataset.summonedBy || '-';
        if (createdAtEl) createdAtEl.textContent = button.dataset.createdAt || '-';
        if (documentLink) {
          var documentUrl = button.dataset.documentUrl || '';
          var documentName = button.dataset.documentName || 'เอกสารแนบ';
          if (documentUrl) {
            documentLink.href = documentUrl;
            documentLink.textContent = documentName;
            documentLink.setAttribute('download', documentName);
          } else {
            documentLink.removeAttribute('href');
            documentLink.removeAttribute('download');
            documentLink.textContent = '-';
          }
        }
        modal.style.display = 'flex';
      }

      function closeDetail() {
        if (modal) modal.style.display = 'none';
      }

      function resetEditDocumentInput() {
        if (editDocumentInput) editDocumentInput.value = '';
        if (editDocumentName) editDocumentName.textContent = 'ยังไม่ได้เลือกไฟล์ใหม่';
        if (editExistingDocument) editExistingDocument.style.display = 'none';
        if (editExistingDocumentLink) {
          editExistingDocumentLink.removeAttribute('href');
          editExistingDocumentLink.removeAttribute('download');
          editExistingDocumentLink.textContent = 'เอกสารแนบ';
        }
      }

      function showExistingEditDocument(url, name) {
        if (!editExistingDocument || !editExistingDocumentLink || !url) return;
        editExistingDocumentLink.href = url;
        editExistingDocumentLink.textContent = name || 'เอกสารแนบ';
        editExistingDocumentLink.setAttribute('download', name || 'written-document');
        editExistingDocument.style.display = 'block';
      }

      function openEdit(button) {
        if (!editModal || !editForm) return;
        var row = button && button.closest ? button.closest('[data-summons-detail-row]') : null;
        var appointmentId = button.dataset.appointmentId || (row && row.dataset.appointmentId) || '';
        if (!appointmentId) return;

        editForm.action = '/registrations/<%= reg.id %>/summons/' + appointmentId + '/edit';
        if (editScheduledInput) editScheduledInput.value = button.dataset.scheduledAtInput || (row && row.dataset.scheduledAtInput) || '';
        if (editNoteInput) editNoteInput.value = decodeURIComponent(button.dataset.note || '');
        resetEditDocumentInput();
        showExistingEditDocument(button.dataset.documentUrl || (row && row.dataset.documentUrl) || '', button.dataset.documentName || (row && row.dataset.documentName) || '');
        editModal.style.display = 'flex';
        if (editScheduledInput) editScheduledInput.focus();
      }

      function closeEdit() {
        if (editModal) editModal.style.display = 'none';
      }

      if (editDocumentButton && editDocumentInput) {
        editDocumentButton.addEventListener('click', function() {
          editDocumentInput.click();
        });
      }

      if (editDocumentInput && editDocumentName) {
        editDocumentInput.addEventListener('change', function() {
          var file = editDocumentInput.files && editDocumentInput.files[0];
          editDocumentName.textContent = file ? file.name : 'ยังไม่ได้เลือกไฟล์ใหม่';
        });
      }

      document.querySelectorAll('[data-summons-detail-open]').forEach(function(button) {
        button.addEventListener('click', function() {
          openDetail(button);
        });
      });

      document.querySelectorAll('[data-summons-detail-row]').forEach(function(row) {
        row.addEventListener('click', function(e) {
          if (e.target.closest('button, a, input, select, textarea, form, [data-no-nav]')) return;
          openDetail(row);
        });
      });

      document.querySelectorAll('[data-summons-detail-close]').forEach(function(button) {
        button.addEventListener('click', closeDetail);
      });

      document.querySelectorAll('[data-summons-edit]').forEach(function(button) {
        button.addEventListener('click', function() {
          openEdit(button);
        });
      });

      document.querySelectorAll('[data-summons-edit-close]').forEach(function(button) {
        button.addEventListener('click', closeEdit);
      });

      document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape' && editModal && editModal.style.display === 'flex') {
          closeEdit();
          return;
        }
        if (e.key === 'Escape' && modal && modal.style.display === 'flex') {
          closeDetail();
        }
      });
    })();

    // Lightbox functionality
    (function() {
      var images = [];
      var currentIndex = 0;
      var overlay = document.getElementById('lightboxOverlay');
      var closeButton = overlay.querySelector('.lightbox-close');
      var prevButton = overlay.querySelector('.lightbox-nav.prev');
      var nextButton = overlay.querySelector('.lightbox-nav.next');

      // Collect available images
      document.querySelectorAll('.lightbox-thumb').forEach(function(img, index) {
        images.push({ src: img.dataset.lightboxSrc || img.src, caption: img.dataset.lightboxCaption || img.alt || '' });
        img.addEventListener('click', function() {
          openLightbox(index);
        });
      });

      window.openLightbox = function(index) {
        if (images.length === 0) return;
        currentIndex = Math.max(0, Math.min(index || 0, images.length - 1));
        showImage();
        overlay.classList.add('active');
        document.body.style.overflow = 'hidden';
      };

      window.closeLightbox = function() {
        overlay.classList.remove('active');
        document.body.style.overflow = '';
      };

      window.navigateLightbox = function(direction) {
        if (images.length === 0) return;
        currentIndex = (currentIndex + direction + images.length) % images.length;
        showImage();
      };

      overlay.addEventListener('click', function(e) {
        if (e.target === overlay) closeLightbox();
      });

      closeButton.addEventListener('click', function(e) {
        e.preventDefault();
        e.stopPropagation();
        closeLightbox();
      });

      prevButton.addEventListener('click', function(e) {
        e.preventDefault();
        e.stopPropagation();
        navigateLightbox(-1);
      });

      nextButton.addEventListener('click', function(e) {
        e.preventDefault();
        e.stopPropagation();
        navigateLightbox(1);
      });

      function showImage() {
        if (images.length === 0) return;
        document.getElementById('lightboxImg').src = images[currentIndex].src;
        document.getElementById('lightboxCaption').textContent = images[currentIndex].caption + ' (' + (currentIndex + 1) + '/' + images.length + ')';
        // Hide nav buttons if only one image
        var navButtons = document.querySelectorAll('.lightbox-nav');
        navButtons.forEach(function(btn) { btn.style.display = images.length > 1 ? 'flex' : 'none'; });
      }

      // Keyboard navigation
      document.addEventListener('keydown', function(e) {
        if (!overlay.classList.contains('active')) return;
        if (e.key === 'Escape') closeLightbox();
        if (e.key === 'ArrowLeft') navigateLightbox(-1);
        if (e.key === 'ArrowRight') navigateLightbox(1);
      });
    })();
  </script>
</body>
</html>
