<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/output.css">
  <script src="https://unpkg.com/lucide@latest"></script>
  <style>
    .glass { background: rgba(255,255,255,0.7); backdrop-filter: blur(12px); }
    .fade-in { animation: fadeIn 0.3s ease-in; }
    @keyframes fadeIn { from { opacity:0; transform:translateY(8px); } to { opacity:1; transform:translateY(0); } }
    .sidebar-gradient { background: linear-gradient(180deg, #0f172a 0%, #1a2332 50%, #162032 100%); }
    .tooltip { position: relative; }
    .tooltip::after { content: attr(data-tip); position: absolute; bottom: 100%; left: 50%; transform: translateX(-50%); padding: 4px 8px; background: #1e293b; color: white; font-size: 12px; border-radius: 6px; white-space: nowrap; opacity: 0; pointer-events: none; transition: opacity 0.2s; }
    .tooltip:hover::after { opacity: 1; }
    .upload-zone { border: 2px dashed #cbd5e1; transition: all 0.2s; }
    .upload-zone:hover { border-color: #22c55e; background: #f0fdf4; }
    .upload-zone.has-file { border-color: #22c55e; background: #f0fdf4; }
  </style>
</head>
<body class="min-h-screen bg-slate-50">
  <div class="flex min-h-screen">
    <%- include('../partials/sidebar') %>
    <div class="flex-1 flex flex-col lg:ml-64">
      <%- include('../partials/topbar') %>
      <main class="flex-1 p-4 sm:p-6 fade-in">
        <%- include('../partials/flash') %>

        <div class="max-w-3xl mx-auto">
          <a href="/registrations" class="inline-flex items-center gap-1.5 text-sm text-slate-500 hover:text-brand-600 mb-4 transition-colors">
            <i data-lucide="arrow-left" class="w-4 h-4"></i> กลับไปจัดการทะเบียน
          </a>
          
          <div class="card p-6 mb-6">
            <h2 class="text-lg font-semibold text-slate-800 mb-2 flex items-center gap-2">
              <i data-lucide="search" class="w-5 h-5 text-brand-500"></i>
              ค้นหาด้วยภาพ
            </h2>
            <p class="text-sm text-slate-500 mb-6">อัพโหลดภาพรถจักรยานยนต์หรือป้ายทะเบียน เพื่อค้นหาข้อมูลในระบบ</p>

            <form method="POST" action="/registrations/search" enctype="multipart/form-data" class="space-y-4">
              <label class="upload-zone rounded-xl p-8 text-center cursor-pointer block" id="search-upload-zone">
                <i data-lucide="image" class="w-10 h-10 text-slate-400 mx-auto mb-3"></i>
                <p class="text-sm font-medium text-slate-600">คลิกเพื่อเลือกภาพ หรือลากไฟล์มาวาง</p>
                <p class="text-xs text-slate-400 mt-1">รองรับ JPG, PNG, WebP (ไม่เกิน 10MB)</p>
                <input type="file" name="search_image" accept="image/*" class="hidden" onchange="previewSearch(this)" required>
                <img id="search-preview" class="max-h-48 rounded-xl mx-auto mt-4 hidden object-cover">
              </label>
              <button type="submit" class="btn btn-primary w-full justify-center">
                <i data-lucide="search" class="w-4 h-4"></i> ค้นหา
              </button>
            </form>
          </div>

          <!-- Results -->
          <% if (results !== null) { %>
          <div class="card p-6">
            <h3 class="text-sm font-semibold text-slate-800 mb-4">
              ผลการค้นหา
              <span class="text-slate-400 font-normal">(พบ <%= results.length %> รายการ)</span>
            </h3>
            <% if (results.length > 0) { %>
            <div class="space-y-4">
              <% results.forEach(function(r) { %>
              <a href="/registrations/<%= r.reg_id %>" class="block p-4 rounded-xl border border-slate-200 hover:border-brand-300 hover:bg-brand-50/50 transition-all">
                <div class="flex items-center gap-4">
                  <% if (r.motorcycle_photo) { %>
                  <img src="<%= signedUrl(r.motorcycle_photo) %>" alt="Motorcycle" class="w-20 h-20 object-cover rounded-xl border border-slate-200">
                  <% } %>
                  <div class="flex-1">
                    <p class="font-semibold text-slate-800"><%= r.first_name %> <%= r.last_name %></p>
                    <p class="text-sm text-slate-500"><%= r.id_number %> · <%= r.license_plate %></p>
                    <p class="text-xs text-slate-400"><%= r.user_type === 'student' ? 'นักศึกษา' : 'บุคลากร' %> · โทร: <%= r.phone || '-' %></p>
                  </div>
                  <div class="text-right">
                    <span class="badge badge-success text-sm">ตรงกัน <%= r.similarity %>%</span>
                  </div>
                </div>
              </a>
              <% }); %>
            </div>
            <% } else { %>
            <div class="text-center py-8">
              <i data-lucide="search-x" class="w-12 h-12 text-slate-300 mx-auto mb-3"></i>
              <p class="text-slate-400">ไม่พบข้อมูลที่ตรงกัน</p>
            </div>
            <% } %>
          </div>
          <% } %>
        </div>

      </main>
    </div>
  </div>
  <script>
    lucide.createIcons();
    function previewSearch(input) {
      const preview = document.getElementById('search-preview');
      const zone = document.getElementById('search-upload-zone');
      if (input.files && input.files[0]) {
        const reader = new FileReader();
        reader.onload = e => { preview.src = e.target.result; preview.classList.remove('hidden'); zone.classList.add('has-file'); };
        reader.readAsDataURL(input.files[0]);
      }
    }
  </script>
</body>
</html>
